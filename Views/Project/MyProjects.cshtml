@using System.Globalization
@model IEnumerable<FreelancePlatform.Models.Project>
@{
    ViewData["Title"] = "Мои проекты";
    var solo = Model.Where(p => !p.IsTeamProject).ToList();
    var team = Model.Where(p => p.IsTeamProject).ToList();

    var unreadByProject = ViewBag.UnreadByProject as Dictionary<int, int>
                          ?? new Dictionary<int, int>();
    var totalUnreadTeam = unreadByProject.Values.Sum();
    
    // Определяем активную вкладку из query string
    var activeTab = Context.Request.Query["tab"].ToString();
    if (string.IsNullOrEmpty(activeTab)) activeTab = "solo";
}

<div class="container mt-5">
    <div class="header mb-4">
        <h1>Мои проекты</h1>
        <p class="text-secondary">Управляйте своими проектами</p>
    </div>

    <div style="display:flex; justify-content:space-between; 
                align-items:center; margin-bottom:1.5rem;">
        <div style="display:flex; gap:4px; 
                    border-bottom:2px solid var(--border); 
                    flex:1;">
            <a href="?tab=solo"
               style="padding:0.6rem 1.4rem;
                      border-radius:0.5rem 0.5rem 0 0;
                      font-weight:@(activeTab == "solo" ? "600" : "500");
                      font-size:0.9rem;
                      text-decoration:none;
                      color:@(activeTab == "solo" ? "var(--primary-light)" : "var(--text-secondary)");
                      background:@(activeTab == "solo" ? "var(--surface)" : "transparent");
                      border:1px solid @(activeTab == "solo" ? "var(--border)" : "transparent");
                      border-bottom:@(activeTab == "solo" ? "3px solid var(--primary)" : "none");
                      transition:all 0.2s;">
                📁 Обычные
                <span style="background:var(--surface-light);
                             color:var(--text-secondary);
                             border:1px solid var(--border);
                             border-radius:9999px;
                             padding:1px 8px;
                             font-size:0.75rem;
                             margin-left:4px;">
                    @solo.Count
                </span>
            </a>
            <a href="?tab=team"
               style="padding:0.6rem 1.4rem;
                      border-radius:0.5rem 0.5rem 0 0;
                      font-weight:@(activeTab == "team" ? "600" : "500");
                      font-size:0.9rem;
                      text-decoration:none;
                      color:@(activeTab == "team" ? "var(--primary-light)" : "var(--text-secondary)");
                      background:@(activeTab == "team" ? "var(--surface)" : "transparent");
                      border:1px solid @(activeTab == "team" ? "var(--border)" : "transparent");
                      border-bottom:@(activeTab == "team" ? "3px solid var(--primary)" : "none");
                      transition:all 0.2s;">
                👥 Командные
                <span style="background:var(--surface-light);
                 color:var(--text-secondary);
                 border:1px solid var(--border);
                 border-radius:9999px;
                 padding:1px 8px;
                 font-size:0.75rem;
                 margin-left:4px;">
                    @team.Count
                </span>
                
                <span id="teamTabBadge"
                      style="background:#ef4444;
                 color:white;
                 border-radius:9999px;
                 padding:1px 8px;
                 font-size:0.75rem;
                 margin-left:2px;
                 font-weight:600;
                 display:@(totalUnreadTeam > 0 ? "inline" : "none");">
                    @(totalUnreadTeam > 0 ? totalUnreadTeam.ToString() : "")
                </span>
            </a>
        </div>

        <!-- Кнопка создания справа -->
        <div style="padding-bottom:2px; margin-left:1rem;">
            <a asp-action="Create" class="btn btn-primary">
                <svg class="meta-icon me-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" 
                          stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Создать
            </a>
        </div>
    </div>

    <!-- ===== ОБЫЧНЫЕ ПРОЕКТЫ ===== -->
    @if (activeTab == "solo")
    {
        @if (solo.Any())
        {
            <div class="projects-list">
                @foreach (var project in solo)
                {
                    <div class="project-card">
                        <div class="project-header">
                            <h3 class="project-title">@project.Title</h3>
                            @switch (project.Status)
                            {
                                case ProjectStatus.Open:
                                    <span class="status-badge status-open">Открыт</span>
                                    break;
                                case ProjectStatus.InProgress:
                                    <span class="status-badge status-inprogress">В работе</span>
                                    break;
                                case ProjectStatus.Completed:
                                    <span class="status-badge status-completed">Завершён</span>
                                    break;
                                case ProjectStatus.Cancelled:
                                    <span class="status-badge status-cancelled">Отменён</span>
                                    break;
                                case ProjectStatus.Paid:
                                    <span class="status-badge status-paid">Оплачен</span>
                                    break;
                            }
                        </div>

                        @if (project.Categories != null && project.Categories.Any())
                        {
                            <div style="display:flex; flex-wrap:wrap; gap:4px; margin-bottom:8px;">
                                @foreach (var cat in project.Categories)
                                {
                                    <span style="padding:2px 10px; border-radius:12px;
                                                 background:#e8e6ff; color:#6c63ff;
                                                 font-size:12px; font-weight:500;">
                                        @cat.Name
                                    </span>
                                }
                            </div>
                        }

                        <div class="project-meta">
                            <div class="meta-item">
                                <span class="project-budget">
                                    @project.Budget.ToString("C", new CultureInfo("ru-RU"))
                                </span>
                            </div>
                            <div class="meta-item">
                                <span>@project.CreatedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>

                        <div class="project-actions">
                            <a asp-controller="Project" asp-action="Details"
                               asp-route-id="@project.Id" class="btn btn-outline">
                                Подробнее
                            </a>
                            @if (project.Status == ProjectStatus.Open 
                                 || project.Status == ProjectStatus.Cancelled)
                            {
                                <a asp-action="Edit" asp-route-id="@project.Id" 
                                   class="btn btn-warning">
                                    Редактировать
                                </a>
                                <form asp-action="Delete" asp-route-id="@project.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Удалить проект?');">
                                    <button type="submit" class="btn btn-danger">Удалить</button>
                                </form>
                            }
                            @if (project.Status == ProjectStatus.Open)
                            {
                                <form asp-action="CancelProject" asp-route-id="@project.Id"
                                      method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline">
                                        Отменить
                                    </button>
                                </form>
                            }
                            @if (project.Status == ProjectStatus.Cancelled)
                            {
                                <form method="post" asp-action="ResumeProject"
                                      asp-route-id="@project.Id" class="d-inline">
                                    <button type="submit" class="btn btn-outline">
                                        Возобновить
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-results">
                <p style="font-size:3rem; margin-bottom:0.5rem;">📁</p>
                <h3>Обычных проектов нет</h3>
                <p>
                    <a asp-action="Create">Создайте первый проект</a>
                </p>
            </div>
        }
    }

    <!-- ===== КОМАНДНЫЕ ПРОЕКТЫ ===== -->
    @if (activeTab == "team")
    {
        @if (team.Any())
        {
            <div class="projects-list">
                @foreach (var project in team)
                {
                    <div class="project-card">
                        <div class="project-header">
                            <h3 class="project-title">@project.Title</h3>
                            <span class="status-badge status-completed">👥 Командный</span>
                            @switch (project.Status)
                            {
                                case ProjectStatus.Open:
                                    <span class="status-badge status-open">Открыт</span>
                                    break;
                                case ProjectStatus.InProgress:
                                    <span class="status-badge status-inprogress">В работе</span>
                                    break;
                                case ProjectStatus.Completed:
                                    <span class="status-badge status-completed">Завершён</span>
                                    break;
                                case ProjectStatus.Cancelled:
                                    <span class="status-badge status-cancelled">Отменён</span>
                                    break;
                                case ProjectStatus.Paid:
                                    <span class="status-badge status-paid">Оплачен</span>
                                    break;
                            }
                        </div>
                        
                        @if (project.Categories != null && project.Categories.Any())
                        {
                            <div style="display:flex; flex-wrap:wrap; gap:4px; margin-bottom:8px;">
                                @foreach (var cat in project.Categories)
                                {
                                    <span style="padding:2px 10px; border-radius:12px;
                                                 background:#e8e6ff; color:#6c63ff;
                                                 font-size:12px; font-weight:500;">
                                        @cat.Name
                                    </span>
                                }
                            </div>
                        }

                        <div class="project-meta">
                            <div class="meta-item">
                                <span class="project-budget">
                                    @project.Budget.ToString("C", new CultureInfo("ru-RU"))
                                </span>
                            </div>
                            <div class="meta-item">
                                <svg class="meta-icon" fill="none" 
                                     stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          stroke-width="2"
                                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                                <span>
                                    @project.Members.Count(m => m.Status == ProjectMemberStatus.Accepted)
                                    участников
                                </span>
                            </div>
                            <div class="meta-item">
                                <span>@project.CreatedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>

                        <div class="project-actions">
                            <div style="position:relative; display:inline-block;">
                                <a asp-controller="TeamProject" asp-action="Details"
                                   asp-route-id="@project.Id"
                                   class="btn btn-outline">
                                    Подробнее
                                </a>
                                @{
                                    var unread = unreadByProject.GetValueOrDefault(project.Id, 0);
                                }
                                <span id="unread-@project.Id"
                                      style="position:absolute;
                                          top:-6px; right:-6px;
                                          background:#ef4444;
                                          color:white;
                                          border-radius:9999px;
                                          padding:1px 7px;
                                          font-size:0.7rem;
                                          font-weight:600;
                                          pointer-events:none;
                                          display:@(unread > 0 ? "inline" : "none");">
                                    @(unread > 0 ? $"{unread} 💬" : "")
                                </span>
                            </div>
                            @if (project.Status == ProjectStatus.Open 
                                 || project.Status == ProjectStatus.Cancelled)
                            {
                                <a asp-controller="Project" asp-action="Edit" 
                                   asp-route-id="@project.Id" 
                                   class="btn btn-warning">
                                    Редактировать
                                </a>
                                <form asp-controller="Project" asp-action="Delete" 
                                      asp-route-id="@project.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Удалить проект?');">
                                    <button type="submit" class="btn btn-danger">Удалить</button>
                                </form>
                            }
                            @if (project.Status == ProjectStatus.Open)
                            {
                                <form asp-controller="Project" asp-action="CancelProject" 
                                      asp-route-id="@project.Id"
                                      method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline">
                                        Отменить
                                    </button>
                                </form>
                            }
                            @if (project.Status == ProjectStatus.Cancelled)
                            {
                                <form method="post" asp-controller="Project" 
                                      asp-action="ResumeProject"
                                      asp-route-id="@project.Id" class="d-inline">
                                    <button type="submit" class="btn btn-outline">
                                        Возобновить
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-results">
                <p style="font-size:3rem; margin-bottom:0.5rem;">👥</p>
                <h3>Командных проектов нет</h3>
                <p>
                    Создайте проект и отметьте галочку
                    <strong>«Командный проект»</strong>
                </p>
                <a asp-action="Create" class="btn btn-primary" style="margin-top:1rem;">
                    Создать командный проект
                </a>
            </div>
        }
    }
</div>