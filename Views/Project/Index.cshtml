@using System.Globalization
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<FreelancePlatform.Models.Project>
@{
    ViewData["Title"] = "Каталог проектов";
    var allCategories = ViewBag.AllCategories as List<FreelancePlatform.Models.Category> 
                        ?? new List<FreelancePlatform.Models.Category>();
    var selectedCategories = ViewBag.SelectedCategories as List<int> ?? new List<int>();
    var currentProjectType = ViewBag.ProjectType as string ?? "";
    var hasTypeFilter = Context.Request.Query.ContainsKey("projectType");
}

<div class="container">
    <div class="header">
        <h1>Каталог проектов</h1>
        <p>Найдите интересные проекты и начните работать уже сегодня</p>
    </div>

    <!-- Filters -->
    <div class="filters-card">
        <div class="filters-title">
            <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.707A1 1 0 013 7V4z"/>
            </svg>
            Фильтры поиска
        </div>

        <form method="get" id="filterForm">

            <!-- Поиск -->
            <div class="filters-search mb-3">
                <label for="search" class="form-label">Поиск по названию</label>
                <div class="search-input">
                    <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="m21 21-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <input type="text" id="search" name="search"
                           value="@ViewBag.Search" class="form-input"
                           placeholder="Введите название проекта..." />
                </div>
            </div>

            <!-- ТИП ПРОЕКТА — новый переключатель -->
            <div class="mb-3">
                <label class="form-label">Тип проекта</label>
                <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                    @foreach (var (val, label, icon) in new[]
                              {
                                  ("",     "Все проекты", "🗂️"),
                                  ("solo", "Обычные",     "📁"),
                                  ("team", "Командные",   "👥")
                              })
                    {
                        // Для "" — активна только если явно передан параметр projectType=""
                        // Для "solo"/"team" — активна если совпадает со значением
                        var isActive = val == "" 
                            ? (hasTypeFilter && currentProjectType == "") 
                            : currentProjectType == val;
    
                        <label style="cursor: pointer;
                  display: inline-flex;
                  align-items: center;
                  gap: 6px;
                  padding: 6px 14px;
                  border-radius: 20px;
                  border: 2px solid #6c63ff;
                  background: @(isActive ? "#6c63ff" : "transparent");
                  color: @(isActive ? "#fff" : "#6c63ff");
                  font-size: 14px;
                  font-weight: 500;
                  transition: all 0.2s;
                  user-select: none;">
                            <input type="radio" name="projectType" value="@val"
                                   @(isActive ? "checked" : "")
                                   style="display: none;"
                                   onchange="toggleRadioChip(this)" />
                            @icon @label
                        </label>
                    }
                </div>
            </div>

            <!-- Категории -->
            @if (allCategories.Any())
            {
                <div class="mb-3">
                    <label class="form-label">Категории</label>
                    <div style="margin-bottom:8px; display:flex; gap:8px;">
                        <button type="button" class="btn btn-outline btn-sm"
                                onclick="selectAllCategories()">Выбрать все</button>
                        <button type="button" class="btn btn-outline btn-sm"
                                onclick="clearAllCategories()">Очистить все</button>
                    </div>
                    <div style="display:flex; flex-wrap:wrap; gap:8px;">
                        @foreach (var cat in allCategories)
                        {
                            var isChecked = selectedCategories.Contains(cat.Id);
                            <label style="cursor:pointer;
                                          display:inline-flex;
                                          align-items:center;
                                          padding:6px 14px;
                                          border-radius:20px;
                                          border:2px solid #6c63ff;
                                          background:@(isChecked ? "#6c63ff" : "transparent");
                                          color:@(isChecked ? "#fff" : "#6c63ff");
                                          font-size:14px;
                                          font-weight:500;
                                          transition:all 0.2s;
                                          user-select:none;">
                                <input type="checkbox" name="categories" value="@cat.Id"
                                       @(isChecked ? "checked" : "")
                                       style="display:none;"
                                       onchange="toggleChip(this)" />
                                @cat.Name
                            </label>
                        }
                    </div>
                </div>
            }

            <!-- Остальные фильтры -->
            <div class="filters-row">
                <div class="input-group">
                    <label for="status">Статус</label>
                    <select name="status" id="status" class="form-input">
                        <option value="">Все статусы</option>
                        <option value="Open" selected="@(ViewBag.Status == "Open")">Открыт</option>
                        <option value="InProgress" selected="@(ViewBag.Status == "InProgress")">В работе</option>
                        <option value="Paid" selected="@(ViewBag.Status == "Paid")">Оплачен</option>
                        <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Отменен</option>
                        <option value="Completed" selected="@(ViewBag.Status == "Completed")">Завершён</option>
                    </select>
                </div>

                <div class="input-group">
                    <label for="minBudget">Мин. бюджет</label>
                    <input type="number" min="0" step="1" id="minBudget" name="minBudget"
                           value="@ViewBag.MinBudget" class="form-input" placeholder="0" />
                </div>

                <div class="input-group">
                    <label for="maxBudget">Макс. бюджет</label>
                    <input type="number" min="0" step="1" id="maxBudget" name="maxBudget"
                           value="@ViewBag.MaxBudget" class="form-input" placeholder="∞" />
                </div>

                <div class="input-group">
                    <label for="sort">Сортировка</label>
                    <select name="sort" id="sort" class="form-select" style="width: 100%">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.Sort))">Дата (новые)</option>
                        <option value="budget_asc" selected="@(ViewBag.Sort == "budget_asc")">Бюджет ↑</option>
                        <option value="budget_desc" selected="@(ViewBag.Sort == "budget_desc")">Бюджет ↓</option>
                    </select>
                </div>

                <div class="submit-group" style="height:45px;">
                    <button type="submit" class="btn btn-primary w-100">
                        <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="m21 21-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        Найти
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Рекомендации для фрилансеров -->
    @if (User.Identity != null && User.Identity.IsAuthenticated 
         && User.IsInRole("Freelancer") && ViewBag.Recommendations != null)
    {
        var recs = ViewBag.Recommendations as List<FreelancePlatform.Dto.Recommendations.RecommendationDto>;
        if (recs != null && recs.Any())
        {
            <div class="filters-card mb-4">
                <h2 class="filters-title">🔥 Рекомендованные проекты</h2>
                <div style="display:flex; flex-wrap:wrap; gap:1rem;">
                    @foreach (var item in recs)
                    {
                        <div style="flex:1; min-width:260px; max-width:360px;">
                            <div class="project-card" style="height:100%; display:flex; flex-direction:column;">
                                <h5 style="color:var(--text-primary); margin-bottom:8px;">@item.Title</h5>
                                @if (item.Categories != null && item.Categories.Any())
                                {
                                    <div style="display:flex; flex-wrap:wrap; gap:4px; margin-bottom:8px;">
                                        @foreach (var cat in item.Categories)
                                        {
                                            <span style="padding:2px 10px; border-radius:12px;
                                                         background:#e8e6ff; color:#6c63ff;
                                                         font-size:12px; font-weight:500;">
                                                @cat
                                            </span>
                                        }
                                    </div>
                                }
                                <div class="project-meta">
                                    <span class="project-budget">
                                        💰 @item.Budget.ToString("C", new CultureInfo("ru-RU"))
                                    </span>
                                </div>
                                <small style="color:var(--text-secondary); flex-grow:1;">
                                    @string.Join(", ", item.Reasons)
                                </small>
                                <div style="margin-top:auto; padding-top:12px;">
                                    <a asp-controller="Project" asp-action="Details"
                                       asp-route-id="@item.Id" class="btn btn-primary">
                                        Открыть
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }

    <!-- Список проектов -->
    <div class="projects-list">
        @if (Model != null && Model.Any())
        {
            @foreach (var project in Model)
            {
                <div class="project-card">
                    <div class="project-header">
                        <h3 class="project-title">@project.Title</h3>

                        <div style="display:flex; gap:6px; align-items:center; flex-wrap:wrap;">
                            <!-- ← пометка командного проекта -->
                            @if (project.IsTeamProject)
                            {
                                <span class="status-badge status-completed">👥 Командный</span>
                            }
                            <span class="status-badge @GetStatusClass(project.Status.ToString())">
                                @GetStatusText(project.Status.ToString())
                            </span>
                        </div>
                    </div>

                    <!-- Категории -->
                    @if (project.Categories != null && project.Categories.Any())
                    {
                        <div style="display:flex; flex-wrap:wrap; gap:4px; margin-bottom:8px;">
                            @foreach (var cat in project.Categories)
                            {
                                <span style="padding:2px 10px; border-radius:12px;
                                             background:#e8e6ff; color:#6c63ff;
                                             font-size:12px; font-weight:500;">
                                    @cat.Name
                                </span>
                            }
                        </div>
                    }

                    <div class="project-meta">
                        <div class="meta-item">
                            <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/>
                            </svg>
                            <span class="project-budget">@project.Budget.ToString("C", new CultureInfo("ru-RU"))</span>
                        </div>
                        <div class="meta-item">
                            <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                            <span>@project.Client?.Email</span>
                        </div>
                        <div class="meta-item">
                            <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <span>@project.CreatedAt.ToString("dd.MM.yyyy")</span>
                        </div>
                        <!-- ← участники только для командных -->
                        @if (project.IsTeamProject)
                        {
                            <div class="meta-item">
                                <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                                <span>
                                    @project.Members.Count(m => m.Status == ProjectMemberStatus.Accepted)
                                    участников
                                </span>
                            </div>
                        }
                    </div>

                    <div class="project-actions">
                        <!-- Обычные проекты — обычная детальная страница -->
                        @if (!project.IsTeamProject)
                        {
                            <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-outline">
                                <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                Подробнее
                            </a>
                        }
                        else
                        {
                            <!-- Командные — ссылка на TeamProject/Details -->
                            <a asp-controller="TeamProject" asp-action="Details"
                               asp-route-id="@project.Id" class="btn btn-outline">
                                <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                Подробнее
                            </a>
                        }

                        @if (User.Identity?.IsAuthenticated == true
                             && User.Identity.Name == project.Client?.UserName
                             && project.Status != ProjectStatus.Completed)
                        {
                            <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-warning">
                                <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                                Редактировать
                            </a>
                            <form asp-action="Delete" asp-route-id="@project.Id" method="post"
                                  style="display:inline;" onsubmit="return confirm('Удалить проект?');">
                                <button type="submit" class="btn btn-danger">
                                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                    Удалить
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="no-results">
                <svg class="no-results-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="m21 21-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <h3>Проекты не найдены</h3>
                <p>Попробуйте изменить параметры поиска</p>
            </div>
        }
    </div>
</div>

<script>
    function toggleChip(checkbox) {
        var label = checkbox.parentElement;
        if (checkbox.checked) {
            label.style.background = '#6c63ff';
            label.style.color = '#fff';
        } else {
            label.style.background = 'transparent';
            label.style.color = '#6c63ff';
        }
    }

    function toggleRadioChip(radio) {
        document.querySelectorAll('input[name="projectType"]').forEach(function(r) {
            var lbl = r.parentElement;
            lbl.style.background = 'transparent';
            lbl.style.color = '#6c63ff';
        });
        var label = radio.parentElement;
        label.style.background = '#6c63ff';
        label.style.color = '#fff';
    }

    function selectAllCategories() {
        document.querySelectorAll('input[name="categories"]').forEach(function (cb) {
            cb.checked = true;
            toggleChip(cb);
        });
    }

    function clearAllCategories() {
        document.querySelectorAll('input[name="categories"]').forEach(function (cb) {
            cb.checked = false;
            toggleChip(cb);
        });
    }
</script>

@functions {
    private string GetStatusClass(string status) => status switch
    {
        "Open"       => "status-open",
        "InProgress" => "status-inprogress",
        "Cancelled"  => "status-cancelled",
        "Completed"  => "status-completed",
        "Paid"       => "status-paid",
        _            => "status-open"
    };

    private string GetStatusText(string status) => status switch
    {
        "Open"       => "Открыт",
        "InProgress" => "В работе",
        "Cancelled"  => "Отменен",
        "Completed"  => "Завершен",
        "Paid"       => "Оплачен",
        _            => "Неизвестно"
    };
}