@using Microsoft.AspNetCore.Mvc.TagHelpers
@model FreelancePlatform.Dto.Projects.CreateProjectDto
@{
ViewData["Title"] = "Создать проект";
var allCategories = ViewBag.AllCategories as List<Category>
?? new List<Category>();
var selectedIds = ViewBag.SelectedCategoryIds as List<int>
?? new List<int>();
var taskTemplates = ViewBag.TaskTemplates as List<TaskTemplate>
?? new List<TaskTemplate>();
}

<div class="container mt-5">
    <!-- Заголовок -->
    <div class="header">
        <h1>Создать проект</h1>
        <p>Опишите ваш проект, чтобы найти исполнителя</p>
    </div>

    <!-- Карточка формы -->
    <div class="filters-card mx-auto" style="max-width: 700px;">
        <form asp-action="Create" method="post" novalidate>
            @Html.AntiForgeryToken()

            <!-- Название -->
            <div class="input-group">
                <label asp-for="Title" class="form-label">Название</label>
                <input asp-for="Title" class="form-input w-100" id="projectTitle" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <!-- Описание -->
            <div class="input-group">
                <label asp-for="Description" class="form-label">Описание</label>
                <textarea asp-for="Description" class="form-input w-100" rows="5"
                          style="resize: vertical;" id="projectDescription"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <!-- Бюджет -->
            <div class="input-group">
                <label asp-for="Budget" class="form-label">Бюджет</label>
                <input asp-for="Budget" class="form-input w-100" type="number" min="0" step="any" />
                <span asp-validation-for="Budget" class="text-danger small"></span>
            </div>

            @if (allCategories.Any())
            {
            <div class="input-group mt-3">
                <label class="form-label">Категории</label>
                <div style="margin-bottom: 8px; display: flex; gap: 8px; flex-wrap: wrap;">
                    <button type="button" class="btn btn-outline btn-sm"
                            onclick="selectAllCategories()">Выбрать все</button>
                    <button type="button" class="btn btn-outline btn-sm"
                            onclick="clearAllCategories()">Очистить все</button>
                    <!-- ★ Кнопка автоподбора -->
                    <button type="button" class="btn btn-sm" id="suggestBtn"
                            style="background: linear-gradient(135deg, #6c63ff 0%, #48c6ef 100%); 
                                       color: #fff; border: none; border-radius: 20px; 
                                       padding: 6px 16px; font-weight: 500; cursor: pointer;
                                       transition: opacity 0.2s;"
                            onmouseover="this.style.opacity='0.85'"
                            onmouseout="this.style.opacity='1'"
                            onclick="suggestCategories()">
                        <svg style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"
                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                        </svg>
                        Подобрать автоматически
                    </button>
                </div>

                <!-- Сообщение-результат автоподбора -->
                <div id="suggestMessage" style="display: none; margin-bottom: 8px; 
                                padding: 8px 14px; border-radius: 8px; font-size: 13px;">
                </div>

                <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                    @foreach (var cat in allCategories)
                    {
                    var isChecked = selectedIds.Contains(cat.Id);
                    <label style="cursor: pointer; display: inline-flex; align-items: center;
                        padding: 6px 14px; border-radius: 20px;
                        border: 2px solid #6c63ff;
                        background: @(isChecked ? "#6c63ff" : "transparent");
                        color: @(isChecked ? "#fff" : "#6c63ff");
                        font-size: 14px; font-weight: 500;
                        transition: all 0.2s; user-select: none;">
                        <input type="checkbox" name="CategoryIds" value="@cat.Id"
                               @(isChecked ? "checked" : "")
                               style="display: none;"
                               onchange="toggleChip(this)" />
                        @cat.Name
                    </label>
                    }
                </div>
            </div>
            }

            <!-- Командный проект -->
            <div class="input-group mt-3">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox"
                           id="isTeamProject" name="IsTeamProject" value="true" />
                    <label class="form-check-label" for="isTeamProject">
                        👥 Командный проект (с групповым чатом и задачами)
                    </label>
                </div>
            </div>

            <!-- Шаблон задач -->
            @if (taskTemplates.Any())
            {
                <div class="input-group mt-4" id="templateSection" style="display:none;">
                    <label class="form-label fw-semibold">
                        📋 Шаблон задач
                        <span class="text-muted fw-normal">(опционально)</span>
                    </label>

                    <div id="noTemplatesHint" style="display:none;">
                        Для выбранных категорий нет готовых шаблонов — добавьте задачи вручную после создания проекта.
                    </div>

                    <div id="templateCards" style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 8px;">
                        <!-- Карточка "Без шаблона" -->
                        <label class="template-card selected"
                               id="template-label-none"
                               data-category-ids="">
                            <input type="radio" name="templateId" value="" checked style="display:none;" />
                            <div class="template-card-content">
                                <span class="template-card-title">Без шаблона</span>
                                <span class="template-card-meta">Добавлю задачи вручную</span>
                            </div>
                        </label>

                        @foreach (var template in taskTemplates)
                        {
                            var categoryIds = string.Join(",", template.Categories.Select(c => c.Id));
                            var tasksJson = System.Text.Json.JsonSerializer.Serialize(
                                template.Items.OrderBy(i => i.OrderIndex).Select(i => i.Title)
                            );

                            <label class="template-card"
                                   id="template-label-@template.Id"
                                   data-category-ids="@categoryIds"
                                   data-tasks='@Html.Raw(tasksJson)'>
                                <input type="radio" name="templateId" value="@template.Id" style="display:none;" />
                                <div class="template-card-content">
                                    <span class="template-card-title">@template.Name</span>
                                    <span class="template-card-meta">@template.Items.Count задач</span>
                                </div>
                            </label>
                        }
                    </div>

                    <div id="templatePreview" style="display:none;" class="template-preview-box">
                        <div class="template-preview-header">
                            Задачи шаблона:
                        </div>
                        <div id="templateTasksList"></div>
                    </div>

                    <small class="text-muted d-block mt-2">
                        💡 Шаблон создаст готовый чек-лист. Вы сможете изменить задачи после создания проекта.
                    </small>
                </div>
            }

            <!-- Кнопка -->
            <div class="text-end mt-4">
                <button type="submit" class="btn btn-success">
                    <svg class="meta-icon me-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M5 13l4 4L19 7" />
                    </svg>
                    Создать
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
@{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
<script>
    function toggleChip(checkbox) {
        var label = checkbox.parentElement;
        if (checkbox.checked) {
            label.style.background = '#6c63ff';
            label.style.color = '#fff';
        } else {
            label.style.background = 'transparent';
            label.style.color = '#6c63ff';
        }
        updateTemplates(); // Обновляем шаблоны при изменении категорий
    }

    function selectAllCategories() {
        document.querySelectorAll('input[name="CategoryIds"]').forEach(function(cb) {
            cb.checked = true;
            toggleChip(cb);
        });
    }

    function clearAllCategories() {
        document.querySelectorAll('input[name="CategoryIds"]').forEach(function(cb) {
            cb.checked = false;
            toggleChip(cb);
        });
    }

    async function suggestCategories() {
        var title = document.getElementById('projectTitle').value;
        var description = document.getElementById('projectDescription').value;
        var msgEl = document.getElementById('suggestMessage');
        var btn = document.getElementById('suggestBtn');

        if (!title.trim() && !description.trim()) {
            msgEl.style.display = 'block';
            msgEl.style.background = '#fff3cd';
            msgEl.style.color = '#856404';
            msgEl.textContent = 'Введите название или описание проекта для автоподбора категорий.';
            return;
        }

        btn.disabled = true;
        btn.textContent = 'Анализируем...';

        try {
            var response = await fetch('@Url.Action("SuggestCategories", "Project")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({ title: title, description: description })
            });

            if (!response.ok) {
                throw new Error('Ошибка сервера: ' + response.status);
            }

            var responseText = await response.text();
            var parsed = JSON.parse(responseText);
            var suggestedIds = parsed.$values || parsed;

            if (!Array.isArray(suggestedIds) || suggestedIds.length === 0) {
                msgEl.style.display = 'block';
                msgEl.style.background = '#f8f9fa';
                msgEl.style.color = '#6c757d';
                msgEl.textContent = 'Не удалось определить категории автоматически. Выберите вручную.';
            } else {
                document.querySelectorAll('input[name="CategoryIds"]').forEach(function (cb) {
                    cb.checked = false;
                    toggleChip(cb);
                });

                suggestedIds.forEach(function (id) {
                    var cb = document.querySelector('input[name="CategoryIds"][value="' + id + '"]');
                    if (cb) {
                        cb.checked = true;
                        toggleChip(cb);
                    }
                });

                msgEl.style.display = 'block';
                msgEl.style.background = '#d4edda';
                msgEl.style.color = '#155724';
                msgEl.textContent = 'Подобрано категорий: ' + suggestedIds.length +
                    '. Вы можете изменить выбор вручную.';
            }
        } catch (e) {
            console.error('Suggest error:', e);
            msgEl.style.display = 'block';
            msgEl.style.background = '#f8d7da';
            msgEl.style.color = '#721c24';
            msgEl.textContent = 'Произошла ошибка при автоподборе: ' + e.message;
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<svg style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>Подобрать автоматически';
        }
    }

    // ============= ШАБЛОНЫ =============
    
    // Получаем выбранные категории
    function getCheckedCategoryIds() {
        var ids = [];
        document.querySelectorAll('input[name="CategoryIds"]:checked').forEach(function(cb) {
            ids.push(cb.value);
        });
        return ids;
    }

    // Обновление видимости шаблонов
    function updateTemplates() {
        var checkedIds = getCheckedCategoryIds();
        var templateSection = document.getElementById('templateSection');
        var noTemplatesHint = document.getElementById('noTemplatesHint');

        if (checkedIds.length === 0) {
            templateSection.style.display = 'none';
            return;
        }

        templateSection.style.display = 'block';
        var anyVisible = false;

        document.querySelectorAll('[id^="template-label-"]').forEach(function(card) {
            if (card.id === 'template-label-none') return;

            var rawIds = card.getAttribute('data-category-ids') || '';

            if (rawIds === '') {
                card.style.display = 'flex';
                anyVisible = true;
                return;
            }

            var templateCatIds = rawIds.split(',').map(function(s) { return s.trim(); });
            var matches = templateCatIds.some(function(tid) {
                return checkedIds.includes(tid);
            });

            card.style.display = matches ? 'flex' : 'none';
            if (matches) anyVisible = true;
        });

        if (noTemplatesHint) {
            noTemplatesHint.style.display = anyVisible ? 'none' : 'block';
        }

        // Если текущий выбранный шаблон скрылся — сбросить на "без шаблона"
        var selectedCard = document.querySelector('[id^="template-label-"]:not(#template-label-none) input[type="radio"]:checked');
        if (selectedCard) {
            var parentCard = selectedCard.closest('[id^="template-label-"]');
            if (parentCard && parentCard.style.display === 'none') {
                selectTemplate('', document.getElementById('template-label-none'));
            }
        }
    }

    // Выбор шаблона
    function selectTemplate(templateId, clickedLabel) {
        // Убираем класс selected у всех карточек
        document.querySelectorAll('.template-card').forEach(function(card) {
            card.classList.remove('selected');
        });

        // Добавляем класс selected к кликнутой карточке
        clickedLabel.classList.add('selected');

        // Отмечаем соответствующий radio
        var radio = clickedLabel.querySelector('input[type="radio"]');
        if (radio) radio.checked = true;

        var preview = document.getElementById('templatePreview');
        var tasksList = document.getElementById('templateTasksList');

        if (!templateId) {
            preview.style.display = 'none';
            return;
        }

        // Получаем задачи из data-атрибута
        var tasksJson = clickedLabel.getAttribute('data-tasks');
        if (tasksJson) {
            try {
                var tasks = JSON.parse(tasksJson);
                if (tasks && tasks.length > 0) {
                    tasksList.innerHTML = tasks.map(function(task, index) {
                        return '<div class="task-item">' +
                            '<span style="width:22px; height:22px; border-radius:50%; background:#e8e6ff;' +
                            'display:flex; align-items:center; justify-content:center; font-size:11px;' +
                            'color:#6c63ff; font-weight:700; flex-shrink:0;">' + (index + 1) + '</span>' +
                            '<span class="task-item-title">' + task + '</span>' +
                            '</div>';
                    }).join('');
                    preview.style.display = 'block';
                } else {
                    preview.style.display = 'none';
                }
            } catch (e) {
                console.error('Ошибка парсинга задач:', e);
                preview.style.display = 'none';
            }
        } else {
            preview.style.display = 'none';
        }
    }

    // ============= ИНИЦИАЛИЗАЦИЯ =============
    
    document.addEventListener('DOMContentLoaded', function() {
        // Обработчики для чекбоксов категорий
        document.querySelectorAll('input[name="CategoryIds"]').forEach(function(cb) {
            cb.addEventListener('change', function() {
                updateTemplates();
            });
        });

        // Обработчики кликов на карточки шаблонов
        document.querySelectorAll('.template-card').forEach(function(card) {
            card.addEventListener('click', function() {
                var templateId = this.querySelector('input[type="radio"]')?.value || '';
                selectTemplate(templateId, this);
            });
        });

        // Первичное обновление шаблонов
        updateTemplates();
    });
</script>