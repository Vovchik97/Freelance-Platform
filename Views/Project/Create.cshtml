@using Microsoft.AspNetCore.Mvc.TagHelpers
@model FreelancePlatform.Dto.Projects.CreateProjectDto
@{
ViewData["Title"] = "Создать проект";
var allCategories = ViewBag.AllCategories as List<FreelancePlatform.Models.Category> 
                    ?? new List<FreelancePlatform.Models.Category>();
var selectedIds = ViewBag.SelectedCategoryIds as List<int> 
                  ?? new List<int>();
}

<div class="container mt-5">
    <!-- Заголовок -->
    <div class="header">
        <h1>Создать проект</h1>
        <p>Опишите ваш проект, чтобы найти исполнителя</p>
    </div>

    <!-- Карточка формы -->
    <div class="filters-card mx-auto" style="max-width: 700px;">
        <form asp-action="Create" method="post" novalidate>
            @Html.AntiForgeryToken()

            <!-- Название -->
            <div class="input-group">
                <label asp-for="Title" class="form-label">Название</label>
                <input asp-for="Title" class="form-input w-100" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <!-- Описание -->
            <div class="input-group">
                <label asp-for="Description" class="form-label">Описание</label>
                <textarea asp-for="Description" class="form-input w-100" rows="5" style="resize: vertical;"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <!-- Бюджет -->
            <div class="input-group">
                <label asp-for="Budget" class="form-label">Бюджет</label>
                <input asp-for="Budget" class="form-input w-100" type="number" min="0" step="any" />
                <span asp-validation-for="Budget" class="text-danger small"></span>
            </div>
            
            @if (allCategories.Any())
            {
                <div class="input-group mt-3">
                    <label class="form-label">Категории</label>
                    <div style="margin-bottom: 8px; display: flex; gap: 8px;">
                        <button type="button" class="btn btn-outline btn-sm" 
                                onclick="selectAllCategories()">Выбрать все</button>
                        <button type="button" class="btn btn-outline btn-sm" 
                                onclick="clearAllCategories()">Очистить все</button>
                    </div>
                    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                        @foreach (var cat in allCategories)
                        {
                            var isChecked = selectedIds.Contains(cat.Id);
                            <label style="cursor: pointer; display: inline-flex; align-items: center; 
                                          padding: 6px 14px; border-radius: 20px; 
                                          border: 2px solid #6c63ff; 
                                          background: @(isChecked ? "#6c63ff" : "transparent"); 
                                          color: @(isChecked ? "#fff" : "#6c63ff"); 
                                          font-size: 14px; font-weight: 500; 
                                          transition: all 0.2s; user-select: none;">
                                <input type="checkbox" name="CategoryIds" value="@cat.Id"
                                       @(isChecked ? "checked" : "")
                                       style="display: none;"
                                       onchange="toggleChip(this)" />
                                @cat.Name
                            </label>
                        }
                    </div>
                </div>
            }

            <!-- Кнопка -->
            <div class="text-end mt-4">
                <button type="submit" class="btn btn-success">
                    <svg class="meta-icon me-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Создать
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
@{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
<script>
    function toggleChip(checkbox) {
        var label = checkbox.parentElement;
        if (checkbox.checked) {
            label.style.background = '#6c63ff';
            label.style.color = '#fff';
        } else {
            label.style.background = 'transparent';
            label.style.color = '#6c63ff';
        }
    }

    function selectAllCategories() {
        document.querySelectorAll('input[name="CategoryIds"]').forEach(function(cb) {
            cb.checked = true;
            toggleChip(cb);
        });
    }

    function clearAllCategories() {
        document.querySelectorAll('input[name="CategoryIds"]').forEach(function(cb) {
            cb.checked = false;
            toggleChip(cb);
        });
    }
</script>