@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@using Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - FreelancePlatform</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/themes.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/buttons.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/cards.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/tables.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/FreelancePlatform.styles.css" asp-append-version="true"/>
</head>
<body class="min-vh-100">

<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">FreelancePlatform</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Project" asp-action="Index">Каталог проектов</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Service" asp-action="Index">Каталог услуг</a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <!-- Пункты для клиентов -->
                    @if (User.IsInRole("Client"))
                    { 
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Payment" asp-action="My">Мои платежи</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Project" asp-action="MyProjects">Мои проекты</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Order" asp-action="MyOrders">Мои заказы</a>
                        </li>
                    }

                    <!-- Пункты для фрилансеров -->
                    @if (User.IsInRole("Freelancer"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Bid" asp-action="MyBids">Мои отклики</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Service" asp-action="MyServices">Мои услуги</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="PublicProfile" asp-action="My">Моя страница</a>
                        </li>
                    }

                    <!-- Чат и баланс для всех аутентифицированных пользователей -->
                    @if (User.Identity!.IsAuthenticated)
                    {
                        if (User.IsInRole("Client") || User.IsInRole("Freelancer"))
                        {
                            <!-- Баланс -->
                            <li class="nav-item d-flex align-items-center ms-3">
                                <div class="dropdown">
                                    <a class="navbar-balance dropdown-toggle" href="#" id="balanceDropdown"
                                       role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <span class="navbar-balance-value">
                                            0 <span class="navbar-balance-currency">₽</span>
                                        </span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="balanceDropdown">
                                        <li><a class="dropdown-item" asp-controller="Payment" asp-action="Deposit">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-2">
                                                <path d="M8 1a.5.5 0 0 1 .5.5v11.793l3.146-3.147a.5.5 0 0 1 .708.708l-4 4a.5.5 0 0 1-.708 0l-4-4a.5.5 0 0 1 .708-.708L7.5 13.293V1.5A.5.5 0 0 1 8 1z"/>
                                            </svg>
                                            Пополнить
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Payment" asp-action="Withdraw">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-2">
                                                <path d="M8 15a.5.5 0 0 1-.5-.5V2.707L4.354 6.854a.5.5 0 1 1-.708-.708l4-4a.5.5 0 0 1 .708 0l4 4a.5.5 0 0 1-.708.708L8.5 2.707V14.5a.5.5 0 0 1-.5.5z"/>
                                            </svg>
                                            Вывести
                                        </a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Payment" asp-action="My">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-2">
                                                <path d="M1.5 1a.5.5 0 0 0-.5.5v12a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5v-12a.5.5 0 0 0-.5-.5H1.5zm13 1v2H2v-2h12zm0 3v8H2v-8h12z"/>
                                            </svg>
                                            История платежей
                                        </a></li>
                                    </ul>
                                </div>
                            </li>

                            <!-- Чат -->
                            <li class="nav-item position-relative ms-2">
                                <a id="chatLink" class="nav-link" asp-controller="Chat" asp-action="Index">Чаты</a>
                                <span id="chatUnreadBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem; padding: 0.35em 0.5em; display: none;">
                                    <span id="chatUnreadCount">0</span>
                                </span>
                            </li>
                        }

                        <!-- Админка -->
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item ms-2">
                                <a class="nav-link" asp-area="Identity" asp-page="/Admin/Index">Админка</a>
                            </li>
                        }

                        <!-- Личный кабинет и выход -->
                        <li class="nav-item ms-2">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index">Личный кабинет</a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Logout">Выход</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Вход</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<main role="main" class="flex-grow-1">
    @RenderBody()
</main>

<footer class="border-top footer text-muted mt-auto">
    <div class="container">
        © 2025 - FreelancePlatform - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.2/signalr.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
