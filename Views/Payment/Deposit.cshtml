@{
    ViewData["Title"] = "Пополнить баланс";
}

<div class="filters-card mx-auto mt-4" style="max-width:600px;">
    <h2 class="filters-title mb-3">Пополнить баланс</h2>

    <form asp-action="Deposit" method="post" novalidate>
        <div class="input-group">
            <label for="amount" class="form-label">Сумма (₽)</label>
            <input type="number" id="amount" name="amount" class="form-input w-100" 
                   min="1" step="0.01" required />
            <span class="text-danger small"></span>
        </div>

        <div class="text-end mt-4">
            <button type="submit" class="btn btn-success">
                Пополнить через Stripe
            </button>
            <a asp-action="My" class="btn btn-outline-secondary ms-2">Назад</a>
        </div>
    </form>
    
    <p class="text-muted mt-3">
        Используется Stripe в <strong>Test Mode</strong>. Карта: 4242 4242 4242 4242, любая дата и CVC.
    </p>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}