@model IEnumerable<FreelancePlatform.Models.Payment>
@{
    ViewData["Title"] = "История платежей";
}

<div class="container mt-5">
    <div class="header">
        <h1>История платежей</h1>
    </div>

    @if (Model.Any())
    {
        <div class="custom-table-container">
            <table class="custom-table">
                <thead>
                <tr>
                    <th>Тип</th>
                    <th>Название</th>
                    <th>Сумма</th>
                    <th>Статус</th>
                    <th>Создан</th>
                    <th>Действия</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var p in Model)
                {
                    
                    var actualStatus = GetActualStatus(p);
                    
                    <tr>
                        <td>
                            @switch(p.Type)
                            {
                                case PaymentType.Order:
                                    <span class="badge bg-info">Заказ</span>
                                    break;
                                case PaymentType.Project:
                                    <span class="badge bg-primary">Проект</span>
                                    break;
                                case PaymentType.Deposit:
                                    <span class="badge bg-success">Пополнение</span>
                                    break;
                                case PaymentType.Withdrawal:
                                    <span class="badge bg-warning">Вывод</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if(p.Type == PaymentType.Order)
                            {
                                @p.Order?.Service?.Title
                            }
                            else if(p.Type == PaymentType.Project)
                            {
                                @p.Project?.Title
                            }
                            else if(p.Type == PaymentType.Deposit)
                            {
                                <span>Пополнение баланса</span>
                            }
                            else if(p.Type == PaymentType.Withdrawal)
                            {
                                <span>Вывод средств</span>
                            }
                        </td>
                        <td>
                            @{
                                var culture = new System.Globalization.CultureInfo("ru-RU");
                                var currentUserId = ViewContext.HttpContext.User
                                    .FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                                bool isIncoming = false;

                                switch (p.Type)
                                {
                                    case PaymentType.Deposit:
                                        isIncoming = true;
                                        break;

                                    case PaymentType.Withdrawal:
                                        isIncoming = false;
                                        break;

                                    case PaymentType.Order:
                                    case PaymentType.Project:
                                        isIncoming = p.PayerId != currentUserId;
                                        break;
                                }

                                var amount = (p.AmountMinor / 100.0M).ToString("C", culture);
                            }

                            <span class="@(isIncoming ? "text-success fw-semibold" : "text-danger fw-semibold")">
                                @(isIncoming ? "+" : "-") @amount
                            </span>
                        </td>
                        <td>
                            <span class="status-badge @GetStatusClass(actualStatus)">
                                @GetStatusText(actualStatus)
                            </span>
                        </td>
                        <td>@p.CreatedAt.ToLocalTime()</td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                @if (p.Type == PaymentType.Deposit || p.Type == PaymentType.Withdrawal || p.PayerId == ViewContext.HttpContext.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                {
                                    <a asp-controller="Payment" asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Подробнее</a>
                                }
                                @if (p.Type == PaymentType.Order && p.OrderId.HasValue)
                                {
                                    <a asp-controller="Order" asp-action="Details" asp-route-id="@p.Order?.Id" class="btn btn-sm btn-outline-primary">Заказ</a>
                                }
                                else if (p.Type == PaymentType.Project && p.ProjectId.HasValue)
                                {
                                    <a asp-controller="Project" asp-action="Details" asp-route-id="@p.Project?.Id" class="btn btn-sm btn-outline-primary">Проект</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">Платежей пока нет.</p>
    }
</div>

@functions {
    private string GetStatusClass(string status) => status switch
    {
        "Pending" => "status-pending",
        "Succeeded" => "status-accepted",
        "Canceled" => "status-rejected",
        "Failed" => "status-completed",
        "Refunded" => "status-refunded",
        _ => "status-pending"
    };

    private string GetStatusText(string status) => status switch
    {
        "Pending" => "Рассматривается",
        "Succeeded" => "Успешно",
        "Canceled" => "Отклонено",
        "Failed" => "Неудачно",
        "Refunded" => "Возвращено",
        _ => "Неизвестно"
    };

    private string GetActualStatus(Payment payment)
    {
        if (payment.Status == PaymentStatus.Pending &&
            (payment.Type == PaymentType.Deposit || payment.Type == PaymentType.Withdrawal))
        {
            return "Canceled";
        }

        if (payment.Status == PaymentStatus.Refunded)
        {
            return "Refunded";
        }
        return payment.Status.ToString(); 
    }
}
