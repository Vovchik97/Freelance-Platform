@model IEnumerable<FreelancePlatform.Models.Payment>
@{
    ViewData["Title"] = "История платежей";
    var currentUserId = ViewContext.HttpContext.User
        .FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var culture = new System.Globalization.CultureInfo("ru-RU");
    var teamShares = ViewBag.TeamShares as List<PaymentShare> ?? new List<PaymentShare>();
    
    var rows = Model
        .Select(p => (RowType: "payment", Date: p.CreatedAt, Payment: (Payment?)p, Share: (PaymentShare?)null))
        .Concat(teamShares
            .Select(s => (RowType: "share", Date: s.CreatedAt, Payment: (Payment?)null, Share: (PaymentShare?)s)))
        .OrderByDescending(r => r.Date)
        .ToList();

    var hasAnything = rows.Any();
}

<div class="container mt-5">
    <div class="header">
        <h1>История платежей</h1>
    </div>

    @if (!hasAnything)
    {
        <p class="text-muted">Платежей пока нет.</p>
    }
    else
    {
        <div class="custom-table-container">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Тип</th>
                        <th>Название</th>
                        <th>Сумма</th>
                        <th>Статус</th>
                        <th>Создан</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        if (row.RowType == "payment")
                        {
                            var p = row.Payment!;
                            var actualStatus = GetActualStatus(p);

                            bool isIncoming = p.Type switch
                            {
                                PaymentType.Deposit    => true,
                                PaymentType.Withdrawal => false,
                                _                      => p.PayerId != currentUserId
                            };

                            decimal rawAmount = p.AmountMinor / 100.0M;
                            decimal displayAmount = rawAmount;
                            decimal commissionAmount = 0;

                            if (isIncoming &&
                                (p.Type == PaymentType.Order || p.Type == PaymentType.Project))
                            {
                                commissionAmount = Math.Round(rawAmount * 0.1m, 2);
                                displayAmount    = rawAmount - commissionAmount;
                            }

                            <tr>
                                <td>
                                    @switch (p.Type)
                                    {
                                        case PaymentType.Order:
                                            <span class="badge bg-info">Заказ</span>
                                            break;
                                        case PaymentType.Project:
                                            @if (p.Project?.IsTeamProject == true)
                                            {
                                                <span class="badge"
                                                      style="background:var(--primary); color:white;">
                                                    👥 Командный
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-primary">Проект</span>
                                            }
                                            break;
                                        case PaymentType.Deposit:
                                            <span class="badge bg-success">Пополнение</span>
                                            break;
                                        case PaymentType.Withdrawal:
                                            <span class="badge bg-warning">Вывод</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (p.Type == PaymentType.Order)
                                    {
                                        @p.Order?.Service?.Title
                                    }
                                    else if (p.Type == PaymentType.Project)
                                    {
                                        @p.Project?.Title
                                    }
                                    else if (p.Type == PaymentType.Deposit)
                                    {
                                        <span>Пополнение баланса</span>
                                    }
                                    else if (p.Type == PaymentType.Withdrawal)
                                    {
                                        <span>Вывод средств</span>
                                    }
                                </td>
                                <td>
                                    <span class="@(isIncoming ? "text-success fw-semibold" : "text-danger fw-semibold")">
                                        @(isIncoming ? "+" : "-")@displayAmount.ToString("C", culture)
                                    </span>
                                    @if (commissionAmount > 0)
                                    {
                                        <div style="color:var(--text-secondary);
                                                    font-size:0.75rem; margin-top:2px;">
                                            комиссия: -@commissionAmount.ToString("C", culture)
                                        </div>
                                    }
                                </td>
                                <td>
                                    <span class="status-badge @GetStatusClass(actualStatus)">
                                        @GetStatusText(actualStatus)
                                    </span>
                                </td>
                                <td>@p.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        @if (p.Type == PaymentType.Deposit
                                             || p.Type == PaymentType.Withdrawal
                                             || p.PayerId == currentUserId)
                                        {
                                            <a asp-controller="Payment" asp-action="Details"
                                               asp-route-id="@p.Id"
                                               class="btn btn-sm btn-outline-secondary">
                                                Подробнее
                                            </a>
                                        }
                                        @if (p.Type == PaymentType.Order && p.OrderId.HasValue)
                                        {
                                            <a asp-controller="Order" asp-action="Details"
                                               asp-route-id="@p.Order?.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                Заказ
                                            </a>
                                        }
                                        else if (p.Type == PaymentType.Project && p.ProjectId.HasValue)
                                        {
                                            @if (p.Project?.IsTeamProject == true)
                                            {
                                                <a asp-controller="TeamProject" asp-action="Details"
                                                   asp-route-id="@p.Project.Id"
                                                   class="btn btn-sm btn-outline-primary">
                                                    Проект
                                                </a>
                                            }
                                            else
                                            {
                                                <a asp-controller="Project" asp-action="Details"
                                                   asp-route-id="@p.Project?.Id"
                                                   class="btn btn-sm btn-outline-primary">
                                                    Проект
                                                </a>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            var share = row.Share!;
                            var commission = Math.Round(share.FinalShare * 0.1m, 2);
                            var received   = share.FinalShare - commission;

                            <tr>
                                <td>
                                    <span class="badge"
                                          style="background:var(--primary); color:white;">
                                        👥 Командный
                                    </span>
                                </td>
                                <td>
                                    @share.Project?.Title
                                </td>
                                <td>
                                    <span class="text-success fw-semibold">
                                        +@received.ToString("C", culture)
                                    </span>
                                    <div style="color:var(--text-secondary);
                                                font-size:0.75rem; margin-top:2px;">
                                        комиссия: -@commission.ToString("C", culture)
                                    </div>
                                </td>
                                <td>
                                    <span class="status-badge status-accepted">Успешно</span>
                                </td>
                                <td>@share.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        @if (share.Project != null)
                                        {
                                            <a asp-controller="TeamProject" asp-action="Details"
                                               asp-route-id="@share.ProjectId"
                                               class="btn btn-sm btn-outline-primary">
                                                Проект
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@functions {
    private string GetStatusClass(string status) => status switch
    {
        "Pending"   => "status-pending",
        "Succeeded" => "status-accepted",
        "Canceled"  => "status-rejected",
        "Failed"    => "status-completed",
        "Refunded"  => "status-refunded",
        _           => "status-pending"
    };

    private string GetStatusText(string status) => status switch
    {
        "Pending"   => "Рассматривается",
        "Succeeded" => "Успешно",
        "Canceled"  => "Отклонено",
        "Failed"    => "Неудачно",
        "Refunded"  => "Возвращено",
        _           => "Неизвестно"
    };

    private string GetActualStatus(Payment payment)
    {
        if (payment.Status == PaymentStatus.Pending &&
            (payment.Type == PaymentType.Deposit || payment.Type == PaymentType.Withdrawal))
        {
            return "Canceled";
        }

        if (payment.Status == PaymentStatus.Refunded)
        {
            return "Refunded";
        }

        return payment.Status.ToString();
    }
}