@model FreelancePlatform.Models.UserBalance
@{
    ViewData["Title"] = "Вывести средства";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success text-center">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger text-center">@TempData["ErrorMessage"]</div>
}

<div class="filters-card mx-auto mt-4" style="max-width:600px;">
    <h2 class="filters-title mb-3">Вывести средства</h2>
    <p class="text-muted">Текущий баланс: <strong>@Model.Balance.ToString("C", new System.Globalization.CultureInfo("ru-RU"))</strong></p>

    <form asp-action="Withdraw" method="post" novalidate>
        <div class="input-group">
            <label for="amount" class="form-label">Сумма (₽)</label>
            <input type="number" id="amount" name="amount" class="form-input w-100" 
                   min="1" step="0.01" max="@Model.Balance" required />
            <span asp-validation-for="Balance" class="text-danger small"></span>
        </div>

        <div class="text-end mt-4">
            <button type="submit" class="btn btn-primary">Вывести</button>
            <a asp-action="My" class="btn btn-outline-secondary ms-2">Назад</a>
        </div>
    </form>
    
    <p class="text-muted mt-3">
        Используется Stripe в <strong>Test Mode</strong>. Карта: 4242 4242 4242 4242, любая дата и CVC.
    </p>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}