@using FreelancePlatform.Models
@model FreelancePlatform.Models.Project
@{
    ViewData["Title"] = Model.Title;
    var tab = ViewBag.Tab as string ?? "overview";
    var isClient = (bool)ViewBag.IsClient;
    var isLead = (bool)ViewBag.IsLead;
    var currentUserId = ViewBag.CurrentUserId as string;
    var currentUserName = ViewBag.CurrentUserName as string;
    var acceptedMembers = ViewBag.AcceptedMembers as List<ProjectMember> ?? new();
    bool canManage = isClient || isLead;
    var isFreelancerOnly = (bool)(ViewBag.IsFreelancerOnly ?? false);
    var unreadChatCount = (int)(ViewBag.UnreadChatCount ?? 0);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info">@TempData["Info"]</div>
}

<div class="container mt-4">
    <div class="header">
        <h1>@Model.Title</h1>
        <p>Командный проект</p>
    </div>

    <!-- Вкладки — стилизуем инлайн через CSS переменные -->
    <div style="display:flex; gap:4px; border-bottom: 2px solid var(--border); margin-bottom: 2rem;">
        @foreach (var (tabId, tabLabel) in new[]
        {
            ("overview", "📋 Обзор"),
            ("team",     "👥 Команда"),
            ("tasks",    "✅ Задачи"),
            ("chat",     "💬 Чат"),
            ("log",      "📜 Журнал")
        })
        {
            @if (isFreelancerOnly && tabId != "overview") { continue; }

            var isActive = tab == tabId;
            <a href="@Url.Action("Details", new { id = Model.Id, tab = tabId })"
               style="padding: 0.6rem 1.2rem;
                      border-radius: 0.5rem 0.5rem 0 0;
                      font-weight: @(isActive ? "600" : "500");
                      font-size: 0.9rem;
                      text-decoration: none;
                      color: @(isActive ? "var(--primary-light)" : "var(--text-secondary)");
                      background: @(isActive ? "var(--surface)" : "transparent");
                      border: 1px solid @(isActive ? "var(--border)" : "transparent");
                      border-bottom: @(isActive ? "3px solid var(--primary)" : "none");
                      transition: all 0.2s;">
                @tabLabel
                @if (tabId == "team")
                {
                    <span style="background:var(--surface-light);
                                 color:var(--text-secondary);
                                 border:1px solid var(--border);
                                 border-radius:9999px;
                                 padding:1px 8px;
                                 font-size:0.75rem;
                                 margin-left:4px;">
                        @Model.Members.Count(m => m.Status == ProjectMemberStatus.Accepted)
                    </span>
                }
                @if (tabId == "tasks")
                {
                    <span style="background:var(--surface-light);
                                 color:var(--text-secondary);
                                 border:1px solid var(--border);
                                 border-radius:9999px;
                                 padding:1px 8px;
                                 font-size:0.75rem;
                                 margin-left:4px;">
                        @Model.Tasks.Count
                    </span>
                }
                @if (tabId == "chat")
                {
                    <span style="background:var(--surface-light);
                         color:var(--text-secondary);
                         border:1px solid var(--border);
                         border-radius:9999px;
                         padding:1px 8px;
                         font-size:0.75rem;
                         margin-left:4px;">
                        @Model.GroupChatMessages.Count
                    </span>
                    @if (unreadChatCount > 0 && tab != "chat")
                    {
                        <span id="chatTabBadge"
                              style="background:#ef4444;
                             color:white;
                             border-radius:9999px;
                             padding:1px 8px;
                             font-size:0.75rem;
                             margin-left:2px;
                             font-weight:600;">
                            @unreadChatCount
                        </span>
                    }
                }
            </a>
        }
    </div>

    <!-- ==================== OVERVIEW ==================== -->
    @if (tab == "overview")
    {
        var userBid = ViewBag.UserBid as Bid;
        var canManageBids = (bool)(ViewBag.CanManageBids ?? false);
        var isClientView = (bool)ViewBag.IsClient;
        var isMemberView = (bool)ViewBag.IsMember;

        <div class="filters-card">
            <h3 class="filters-title">Описание проекта</h3>
            <p style="color:var(--text-secondary); line-height:1.6;">@Model.Description</p>

            <div style="border-top:1px solid var(--border); margin:1.5rem 0;"></div>

            <div class="project-meta">
                <div class="meta-item">
                    <strong style="color:var(--text-primary);">Бюджет:</strong>
                    <span class="project-budget ms-1">
                        @Model.Budget.ToString("C", new System.Globalization.CultureInfo("ru-RU"))
                    </span>
                </div>
                <div class="meta-item">
                    <strong style="color:var(--text-primary);">Статус:</strong>
                    <span class="ms-1">
                        @switch (Model.Status)
                        {
                            case ProjectStatus.Open:
                                <span class="status-badge status-open">Открыт</span>
                                break;
                            case ProjectStatus.InProgress:
                                <span class="status-badge status-inprogress">В работе</span>
                                break;
                            case ProjectStatus.Completed:
                                <span class="status-badge status-completed">Завершён</span>
                                break;
                            case ProjectStatus.Cancelled:
                                <span class="status-badge status-cancelled">Отменён</span>
                                break;
                            default:
                                <span class="status-badge status-pending">@Model.Status</span>
                                break;
                        }
                    </span>
                </div>
                <div class="meta-item">
                    <strong style="color:var(--text-primary);">Клиент:</strong>
                    <span class="ms-1">@Model.Client?.UserName</span>
                </div>
            </div>

            <div style="border-top:1px solid var(--border); margin:1.5rem 0;"></div>

            <!-- Статистика -->
            <div class="stats-grid" style="grid-template-columns:repeat(3,1fr); margin-top:0;">
                <div class="stat-card">
                    <div class="stat-value">
                        @Model.Members.Count(m => m.Status == ProjectMemberStatus.Accepted)
                    </div>
                    <div class="stat-label">Участников</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">
                        @Model.Tasks.Count(t => t.Status == ProjectTaskStatus.Done)
                    </div>
                    <div class="stat-label">Задач выполнено</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">@Model.Bids.Count</div>
                    <div class="stat-label">Заявок</div>
                </div>
            </div>

            <div style="border-top:1px solid var(--border); margin:1.5rem 0;"></div>

            <!-- Действия клиента -->
            @if (isClientView)
            {
                <div class="project-actions">
                    <a asp-action="Edit" asp-controller="TeamProject"
                       asp-route-id="@Model.Id" class="btn btn-warning">
                        ✏️ Редактировать
                    </a>
                    @if (Model.Status == ProjectStatus.Open)
                    {
                        <form asp-action="CancelProject" asp-controller="TeamProject"
                              asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline">
                                ✕ Отменить проект
                            </button>
                        </form>
                    }
                    @if (Model.Status == ProjectStatus.Cancelled)
                    {
                        <form asp-action="ResumeProject" asp-controller="TeamProject"
                              asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline">
                                ↺ Возобновить проект
                            </button>
                        </form>
                        <form asp-action="DeleteProject" asp-controller="TeamProject"
                              asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('Удалить проект?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">
                                🗑 Удалить проект
                            </button>
                        </form>
                    }
                </div>
            }

            <!-- Форма отклика для фрилансера -->
            @if (User.IsInRole("Freelancer") && !isMemberView && !isClientView)
            {
                @if (userBid == null && Model.Status == ProjectStatus.Open)
                {
                    <div class="filters-card"
                         style="margin-top:1.5rem; box-shadow:none;
                                border-color:var(--primary-light);">
                        <h5 class="filters-title" style="font-size:1rem;">
                            📝 Откликнуться на проект
                        </h5>
                        <form asp-action="SubmitBid" asp-controller="TeamProject" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="projectId" value="@Model.Id" />
                            <div class="filters-row">
                                <div class="input-group">
                                    <label class="form-label">Ваша цена (₽)</label>
                                    <input type="number" name="amount" class="form-input"
                                           min="1" required placeholder="5000" />
                                </div>
                                <div class="input-group">
                                    <label class="form-label">Срок (дней)</label>
                                    <input type="number" name="durationInDays" class="form-input"
                                           min="1" required placeholder="14" />
                                </div>
                                <div class="input-group">
                                    <label class="form-label">Комментарий</label>
                                    <input type="text" name="comment" class="form-input"
                                           placeholder="Расскажите о себе..." />
                                </div>
                            </div>
                            <div style="margin-top:1rem;">
                                <button type="submit" class="btn btn-primary">
                                    Отправить заявку
                                </button>
                            </div>
                        </form>
                    </div>
                }
                else if (userBid != null)
                {
                    <div class="project-card" style="margin-top:1.5rem; border-color:var(--primary-light);">
                        <p style="color:var(--text-primary); margin:0;">
                            ✅ Вы уже откликнулись на этот проект.
                            Ваша заявка:
                            <span class="project-budget">
                                @userBid.Amount.ToString("C", new System.Globalization.CultureInfo("ru-RU"))
                            </span>
                            · @userBid.DurationInDays дн.
                            ·
                            @switch (userBid.Status)
                            {
                                case BidStatus.Pending:
                                    <span class="status-badge status-pending">Рассматривается</span>
                                    break;
                                case BidStatus.Accepted:
                                    <span class="status-badge status-open">Принята</span>
                                    break;
                                case BidStatus.Rejected:
                                    <span class="status-badge status-cancelled">Отклонена</span>
                                    break;
                            }
                        </p>
                    </div>
                }
            }
        </div>

        <!-- Таблица заявок для клиента и лида -->
        @if (canManageBids && Model.Bids.Any())
        {
            <div class="filters-card" style="margin-top:1.5rem;">
                <h3 class="filters-title">📋 Заявки на проект</h3>
                <div class="custom-table-container"
                     style="padding:0; box-shadow:none; border:none; margin-bottom:0;">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Фрилансер</th>
                                <th>Цена</th>
                                <th>Срок (дней)</th>
                                <th>Комментарий</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bid in Model.Bids.OrderByDescending(b => b.CreatedAt))
                            {
                                <tr>
                                    <td style="color:var(--text-primary);">
                                        @bid.Freelancer?.UserName
                                    </td>
                                    <td>
                                        <span class="project-budget">
                                            @bid.Amount.ToString("C", new System.Globalization.CultureInfo("ru-RU"))
                                        </span>
                                    </td>
                                    <td>@bid.DurationInDays</td>
                                    <td style="color:var(--text-secondary);">@bid.Comment</td>
                                    <td>
                                        @switch (bid.Status)
                                        {
                                            case BidStatus.Pending:
                                                <span class="status-badge status-pending">Рассматривается</span>
                                                break;
                                            case BidStatus.Accepted:
                                                <span class="status-badge status-open">Принята</span>
                                                break;
                                            case BidStatus.Rejected:
                                                <span class="status-badge status-cancelled">Отклонена</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (bid.Status == BidStatus.Pending)
                                        {
                                            <div class="project-actions" style="justify-content:center;">
                                                <form asp-action="AcceptBid" asp-controller="TeamProject"
                                                      method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="projectId" value="@Model.Id" />
                                                    <input type="hidden" name="bidId" value="@bid.Id" />
                                                    <button class="btn btn-primary" style="font-size:0.8rem; padding:4px 10px;">
                                                        ✓ Принять
                                                    </button>
                                                </form>
                                                <form asp-action="RejectBid" asp-controller="TeamProject"
                                                      method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="projectId" value="@Model.Id" />
                                                    <input type="hidden" name="bidId" value="@bid.Id" />
                                                    <button class="btn btn-outline" style="font-size:0.8rem; padding:4px 10px;">
                                                        ✕ Отклонить
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        else
                                        {
                                            <span style="color:var(--text-secondary); font-size:0.8rem;">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }

    <!-- ==================== TEAM ==================== -->
    @if (tab == "team")
    {
        <div class="filters-card">
            <h3 class="filters-title">👥 Участники команды</h3>

            @if (canManage)
            {
                <!-- Форма приглашения — вложенная filters-card -->
                <div class="filters-card"
                     style="margin-bottom:1.5rem;
                            box-shadow:none;
                            border-color:var(--primary-light);">
                    <h5 class="filters-title" style="font-size:1rem; margin-bottom:1rem;">
                        ➕ Пригласить участника
                    </h5>
                    <form asp-action="InviteMember" asp-controller="TeamProject" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ProjectId" value="@Model.Id" />
                        <div class="filters-row" style="grid-template-columns:1fr 1fr auto;">
                            <div class="input-group">
                                <label class="form-label">Имя пользователя</label>
                                <input type="text" name="UserName"
                                       class="form-input"
                                       placeholder="@@username" required />
                            </div>
                            <div class="input-group">
                                <label class="form-label">Роль</label>
                                <select name="Role" class="form-input">
                                    <option value="0">Участник</option>
                                    @if (isClient)
                                    {
                                        <option value="1">⭐ Lead</option>
                                    }
                                </select>
                            </div>
                            <div class="submit-group" style="height: 45px">
                                <button type="submit" class="btn btn-primary w-100">
                                    Пригласить
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            }

            <!-- Таблица участников -->
            <div class="custom-table-container"
                 style="padding:0; box-shadow:none; border:none; margin-bottom:0;">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Участник</th>
                            <th>Роль</th>
                            <th>Статус</th>
                            <th>Дата вступления</th>
                            @if (canManage)
                            {
                                <th>Действия</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Клиент -->
                        <tr>
                            <td style="font-weight:600; color:var(--text-primary);">
                                @Model.Client?.UserName
                            </td>
                            <td><span class="status-badge status-accepted">Клиент</span></td>
                            <td><span class="status-badge status-open">Активен</span></td>
                            <td>@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            @if (canManage)
                            {
                                <td>—</td>
                            }
                        </tr>

                        @foreach (var member in Model.Members.OrderBy(m => m.Status))
                        {
                            <tr>
                                <td style="color:var(--text-primary);">@member.UserName</td>
                                <td>
                                    @if (member.Role == ProjectMemberRole.Lead)
                                    {
                                        <span class="status-badge status-completed">⭐ Lead</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-pending">Участник</span>
                                    }
                                </td>
                                <td>
                                    @switch (member.Status)
                                    {
                                        case ProjectMemberStatus.Accepted:
                                            <span class="status-badge status-open">Принят</span>
                                            break;
                                        case ProjectMemberStatus.Pending:
                                            <span class="status-badge status-pending">Ожидает</span>
                                            break;
                                        case ProjectMemberStatus.Rejected:
                                            <span class="status-badge status-cancelled">Отклонил</span>
                                            break;
                                    }
                                </td>
                                <td>@member.JoinedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                @if (canManage)
                                {
                                    <td>
                                        <div class="project-actions" style="justify-content:center;">
                                            @if (isClient
                                                 && member.Role != ProjectMemberRole.Lead
                                                 && member.Status == ProjectMemberStatus.Accepted)
                                            {
                                                <form asp-action="SetLead"
                                                      asp-controller="TeamProject" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="memberId" value="@member.Id" />
                                                    <button class="btn btn-outline">⭐ Lead</button>
                                                </form>
                                            }
                                            <form asp-action="RemoveMember"
                                                  asp-controller="TeamProject" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="memberId" value="@member.Id" />
                                                <button class="btn btn-danger">✕ Удалить</button>
                                            </form>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- ==================== TASKS ==================== -->
    @if (tab == "tasks")
    {
        <div class="filters-card">
            <h3 class="filters-title">✅ Задачи проекта</h3>

            @if (canManage)
            {
                <div class="filters-card"
                     style="margin-bottom:1.5rem;
                            box-shadow:none;
                            border-color:var(--primary-light);">
                    <h5 class="filters-title" style="font-size:1rem; margin-bottom:1rem;">
                        ➕ Создать задачу
                    </h5>
                    <form asp-action="CreateTask" asp-controller="TeamProject" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ProjectId" value="@Model.Id" />
                        <div class="filters-row">
                            <div class="input-group">
                                <label class="form-label">Название</label>
                                <input type="text" name="Title" class="form-input" required />
                            </div>
                            <div class="input-group">
                                <label class="form-label">Описание</label>
                                <input type="text" name="Description" class="form-input" />
                            </div>
                            <div class="input-group">
                                <label class="form-label">Исполнитель</label>
                                <select name="AssignedToUserId" class="form-input">
                                    <option value="">— Не назначен —</option>
                                    @foreach (var m in acceptedMembers)
                                    {
                                        <option value="@m.UserId">@m.UserName</option>
                                    }
                                </select>
                            </div>
                            <div class="submit-group" style="height: 45px">
                                <button type="submit" class="btn btn-primary w-100">Создать</button>
                            </div>
                        </div>
                    </form>
                </div>
            }

            @{
                var grouped = Model.Tasks
                    .GroupBy(t => t.Status)
                    .ToDictionary(g => g.Key, g => g.ToList());

                var columns = new[]
                {
                    (ProjectTaskStatus.Todo,       "📋 К выполнению", "status-pending"),
                    (ProjectTaskStatus.InProgress, "🔄 В процессе",   "status-inprogress"),
                    (ProjectTaskStatus.Done,       "✅ Выполнено",    "status-open")
                };
            }

            <!-- Канбан доска -->
            <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1rem;">
                @foreach (var (status, label, badgeClass) in columns)
                {
                    var tasks = grouped.GetValueOrDefault(status, new List<ProjectTask>());

                    <!-- Колонка — используем surface-light + border из переменных -->
                    <div style="background:var(--surface-light);
                                border:1px solid var(--border);
                                border-radius:1rem;
                                padding:1rem;
                                min-height:300px;">

                        <!-- Заголовок колонки -->
                        <div style="display:flex; justify-content:space-between;
                                    align-items:center;
                                    margin-bottom:1rem;
                                    padding-bottom:0.75rem;
                                    border-bottom:2px solid var(--border);">
                            <span style="font-weight:600; color:var(--text-primary); font-size:0.9rem;">
                                @label
                            </span>
                            <span class="status-badge @badgeClass">@tasks.Count</span>
                        </div>

                        <!-- Карточки задач -->
                        @foreach (var task in tasks)
                        {
                            <!-- project-card уже имеет var(--surface) фон -->
                            <div class="project-card"
                                 style="margin-bottom:0.75rem; padding:1rem;">

                                <div class="project-header" style="margin-bottom:0.5rem;">
                                    <span class="project-title" style="font-size:0.95rem;">
                                        @task.Title
                                    </span>
                                    @if (canManage)
                                    {
                                        <form asp-action="DeleteTask"
                                              asp-controller="TeamProject"
                                              method="post" style="margin:0;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="taskId" value="@task.Id" />
                                            <button class="btn btn-danger"
                                                    style="padding:2px 8px; font-size:12px;">
                                                ✕
                                            </button>
                                        </form>
                                    }
                                </div>

                                @if (!string.IsNullOrEmpty(task.Description))
                                {
                                    <p class="project-description"
                                       style="font-size:0.8rem; margin-bottom:0.5rem;">
                                        @task.Description
                                    </p>
                                }

                                @if (!string.IsNullOrEmpty(task.AssignedToUserName))
                                {
                                    <div class="meta-item" style="margin-bottom:0.75rem;">
                                        <svg class="meta-icon" fill="none"
                                             stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                  stroke-width="2"
                                                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                        </svg>
                                        <span style="color:var(--primary-light); font-weight:500;">
                                            @task.AssignedToUserName
                                        </span>
                                    </div>
                                }

                                <!-- Кнопки смены статуса -->
                                <div class="project-actions" style="gap:0.25rem; flex-wrap:wrap;">
                                    @if (status != ProjectTaskStatus.Todo)
                                    {
                                        <button class="btn btn-outline task-status-btn"
                                                style="font-size:0.75rem; padding:4px 8px;"
                                                data-task-id="@task.Id" data-status="0">
                                            ← К выполнению
                                        </button>
                                    }
                                    @if (status != ProjectTaskStatus.InProgress)
                                    {
                                        <button class="btn btn-warning task-status-btn"
                                                style="font-size:0.75rem; padding:4px 8px;"
                                                data-task-id="@task.Id" data-status="1">
                                            🔄 В процессе
                                        </button>
                                    }
                                    @if (status != ProjectTaskStatus.Done)
                                    {
                                        <button class="btn btn-primary task-status-btn"
                                                style="font-size:0.75rem; padding:4px 8px;
                                                       background:var(--success);"
                                                data-task-id="@task.Id" data-status="2">
                                            ✅ Выполнено
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        @if (!tasks.Any())
                        {
                            <div style="text-align:center;
                                        color:var(--text-secondary);
                                        font-size:0.875rem;
                                        padding:2rem 0;">
                                Нет задач
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <!-- ==================== CHAT ==================== -->
    @if (tab == "chat")
    {
        <input type="hidden" id="projectId" value="@Model.Id" />
        <input type="hidden" id="currentUserId" value="@currentUserId" />
        <input type="hidden" id="currentUserName" value="@currentUserName" />
        @Html.AntiForgeryToken()

        <div class="filters-card" style="padding:0; overflow:hidden;">

            <!-- Шапка чата — gradient из переменных -->
            <div style="padding:16px 20px;
                        background:var(--gradient);
                        color:white;
                        display:flex; align-items:center; gap:12px;
                        border-radius:1rem 1rem 0 0;">
                <div style="width:42px; height:42px;
                            background:rgba(255,255,255,0.2);
                            border-radius:50%;
                            display:flex; align-items:center;
                            justify-content:center; font-size:22px;">
                    💬
                </div>
                <div>
                    <div style="font-weight:600; font-size:16px;">Групповой чат команды</div>
                    <div style="font-size:12px; opacity:0.85;">
                        @@username — для упоминания участника
                    </div>
                </div>
            </div>

            <!-- Список сообщений — surface-light фон -->
            <ul id="groupMessages"
                style="height:450px; overflow-y:auto;
                       padding:16px; margin:0;
                       background:var(--surface-light);
                       list-style:none;">
                @foreach (var msg in Model.GroupChatMessages)
                {
                    var isMe = msg.SenderId == currentUserId;
                    <li class="d-flex mb-2 @(isMe ? "justify-content-end" : "justify-content-start")">
                        <div class="message-bubble @(isMe ? "me" : "other")">
                            @if (!isMe)
                            {
                                <div class="message-sender"
                                     style="font-size:0.75rem;
                                            font-weight:600;
                                            color:var(--primary-light);
                                            margin-bottom:4px;">
                                    @msg.SenderName
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(msg.Text))
                            {
                                <div>@Html.Raw(FormatMentions(msg.Text))</div>
                            }

                            @* Вложения — те же классы что в обычном чате *@
                            @if (msg.Attachments != null && msg.Attachments.Any())
                            {
                                var images = msg.Attachments
                                    .Where(a => a.AttachmentType?.StartsWith("image/") == true).ToList();
                                var videos = msg.Attachments
                                    .Where(a => a.AttachmentType?.StartsWith("video/") == true).ToList();
                                var audios = msg.Attachments
                                    .Where(a => a.AttachmentType?.StartsWith("audio/") == true).ToList();
                                var otherFiles = msg.Attachments
                                    .Where(a => a.AttachmentType != null
                                        && !a.AttachmentType.StartsWith("image/")
                                        && !a.AttachmentType.StartsWith("video/")
                                        && !a.AttachmentType.StartsWith("audio/")).ToList();

                                @if (images.Any())
                                {
                                    <div class="image-grid">
                                        @foreach (var img in images)
                                        {
                                            <a href="@img.AttachmentUrl" target="_blank" class="image-link">
                                                <img src="@img.AttachmentUrl"
                                                     alt="@img.AttachmentName"
                                                     class="message-image" />
                                            </a>
                                        }
                                    </div>
                                }
                                @if (videos.Any())
                                {
                                    <div class="image-grid">
                                        @foreach (var vid in videos)
                                        {
                                            <video src="@vid.AttachmentUrl"
                                                   class="message-video"
                                                   controls style="width:100%;"></video>
                                        }
                                    </div>
                                }
                                @if (audios.Any())
                                {
                                    <div class="audio-grid">
                                        @foreach (var aud in audios)
                                        {
                                            <audio src="@aud.AttachmentUrl"
                                                   controls style="width:100%;"></audio>
                                        }
                                    </div>
                                }
                                @if (otherFiles.Any())
                                {
                                    <div class="attachments-grid">
                                        @foreach (var file in otherFiles)
                                        {
                                            var ext = System.IO.Path.GetExtension(
                                                file.AttachmentName)?.TrimStart('.').ToUpper();
                                            <a href="@file.AttachmentUrl"
                                               target="_blank" class="file-attachment">
                                                <div class="file-icon-box"><span>@ext</span></div>
                                                <div class="file-info">
                                                    <div class="file-name">@file.AttachmentName</div>
                                                </div>
                                            </a>
                                        }
                                    </div>
                                }
                            }

                            <div class="message-time">
                                @msg.SentAt.ToLocalTime().ToString("g")
                            </div>
                        </div>
                    </li>
                }
            </ul>

            <!-- Превью вложений перед отправкой -->
            <div id="groupAttachmentsPreview"
                 style="display:none;
                        flex-wrap:wrap;
                        gap:8px;
                        padding:10px 16px;
                        background:var(--surface);
                        border-top:1px solid var(--border);">
            </div>

            <!-- Поле ввода — surface фон -->
            <div style="padding:16px;
                        background:var(--surface);
                        border-top:1px solid var(--border);
                        border-radius:0 0 1rem 1rem;">
                <div style="display:flex; gap:8px; align-items:center;">
                    <div style="position:relative; flex:1;">
                        <input type="text" id="groupMessageInput"
                               class="form-input"
                               style="width:100%; padding-right:40px;"
                               placeholder="Введите сообщение... (@@username для упоминания)" />
                        <label for="groupFileInput"
                               style="position:absolute; right:10px; top:50%;
                                      transform:translateY(-50%);
                                      cursor:pointer; font-size:18px; margin:0;">
                            📎
                        </label>
                        <input type="file" id="groupFileInput" style="display:none;" multiple />
                    </div>
                    <button id="groupSendBtn" class="btn btn-primary" style="flex-shrink:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                             viewBox="0 0 24 24" fill="currentColor">
                            <path d="M2 21L23 12 2 3v7l15 2-15 2v7z"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- ==================== LOG ==================== -->
    @if (tab == "log")
    {
        <div class="filters-card">
            <h3 class="filters-title">📜 Журнал изменений</h3>

            @if (Model.ActivityLogs.Any())
            {
                @foreach (var log in Model.ActivityLogs)
                {
                    <!-- project-card даёт правильный фон -->
                    <div class="project-card"
                         style="display:flex; align-items:flex-start;
                                gap:1rem; padding:1rem; margin-bottom:0.75rem;">
                        <div style="width:38px; height:38px; flex-shrink:0;
                                    border-radius:50%;
                                    background:var(--gradient);
                                    display:flex; align-items:center;
                                    justify-content:center; font-size:16px;">
                            📝
                        </div>
                        <div style="flex:1;">
                            <div style="color:var(--text-primary); font-size:0.9rem; margin-bottom:4px;">
                                @log.Action
                            </div>
                            <div class="meta-item">
                                @if (log.ActorName != null)
                                {
                                    <span style="color:var(--primary-light); font-weight:500;">
                                        @@log.ActorName
                                    </span>
                                    <span style="color:var(--border); margin:0 4px;">·</span>
                                }
                                <span style="color:var(--text-secondary); font-size:0.8rem;">
                                    @log.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                </span>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="no-results">
                    <p style="font-size:2rem; margin-bottom:0.5rem;">📜</p>
                    <h3>Действий пока не было</h3>
                    <p>Здесь будет история изменений проекта</p>
                </div>
            }
        </div>
    }
</div>

@functions {
    string FormatMentions(string text)
    {
        return System.Text.RegularExpressions.Regex.Replace(
            System.Net.WebUtility.HtmlEncode(text),
            @"@(\w+)",
            "<strong style='color:var(--primary-light)'>@$1</strong>"
        );
    }
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.2/signalr.min.js"></script>
    <script src="~/js/groupChat.js"></script>
}