@model List<FreelancePlatform.Models.ProjectMember>
@{
    ViewData["Title"] = "Мои приглашения";
}

<div class="container mt-4">
    <div class="header">
        <h1>Приглашения в проекты</h1>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">У вас нет активных приглашений.</div>
    }
    else
    {
        @foreach (var invite in Model)
        {
            <div class="project-card d-flex justify-content-between align-items-center">
                <div>
                    <h5>@invite.Project.Title</h5>
                    <small class="text-muted">
                        Роль: @(invite.Role == ProjectMemberRole.Lead ? "⭐ Lead" : "Участник")
                    </small>
                </div>
                <div class="d-flex gap-2">
                    <form asp-action="AcceptInvite" asp-controller="TeamProject" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="memberId" value="@invite.Id" />
                        <button class="btn btn-success">✅ Принять</button>
                    </form>
                    <form asp-action="DeclineInvite" asp-controller="TeamProject" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="memberId" value="@invite.Id" />
                        <button class="btn btn-outline-danger">✕ Отклонить</button>
                    </form>
                </div>
            </div>
        }
    }
</div>