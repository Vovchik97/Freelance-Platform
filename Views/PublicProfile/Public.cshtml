@using System.Globalization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model FreelancePlatform.Dto.Profiles.PublicProfileDto

@inject Microsoft.AspNetCore.Identity.UserManager<IdentityUser> UserManager

@{
    var currentUserId = UserManager.GetUserId(User);
    var isOwnProfile  = currentUserId == Model.UserId;
    ViewData["Title"] = isOwnProfile ? "Моя страница" : $"{Model.UserName} — Профиль";
}

<div class="container mt-4">

    <!-- ШАПКа профиля -->
    <div class="filters-card mb-4">
        <div class="row g-4 align-items-start">

            <!-- Имя + кнопка редактирования -->
            <div class="col-md-4">
                <h1 class="mb-1">@Model.UserName</h1>
                @if (string.IsNullOrWhiteSpace(Model.AboutMe))
                {
                    <p class="text-muted">Пользователь пока не заполнил раздел «О себе».</p>
                }
                else
                {
                    <p>@Model.AboutMe</p>
                }
                @if (isOwnProfile)
                {
                    <a asp-action="Edit" class="btn btn-outline-primary btn-sm">Редактировать профиль</a>
                }
            </div>

            <!-- Рейтинг + бар-чарт критериев -->
            <div class="col-md-8">
                @if (Model.AverageRating.HasValue && Model.ReviewsCount > 0)
                {
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div style="font-size:52px; font-weight:700; color:#6c63ff; line-height:1;">
                            @Model.AverageRating.Value.ToString("F1")
                        </div>
                        <div>
                            @await Html.PartialAsync("_StarRating", Model.AverageRating.Value)
                            <div class="text-muted mt-1" style="font-size:13px;">
                                @Model.ReviewsCount отзывов по всем услугам
                            </div>
                        </div>
                    </div>

                    <!-- Бар-чарт -->
                    <div class="criteria-chart">
                        @{
                            void ProfileBar(string label, double? val)
                            {
                                if (!val.HasValue) return;
                                double pct = val.Value / 5.0 * 100;
                                <div class="chart-row">
                                    <div class="chart-label">@label</div>
                                    <div class="chart-bar-wrap">
                                        <div class="chart-bar"
                                             style="width:@pct.ToString("F1", CultureInfo.InvariantCulture)%">
                                        </div>
                                    </div>
                                    <div class="chart-val">@val.Value.ToString("F1")</div>
                                </div>
                            }
                        }
                        @{ ProfileBar("Качество работы",   Model.AvgQuality); }
                        @{ ProfileBar("Коммуникация",      Model.AvgCommunication); }
                        @{ ProfileBar("Соблюдение сроков", Model.AvgDeadline); }
                        @{ ProfileBar("Цена / качество",   Model.AvgPrice); }
                    </div>
                }
                else
                {
                    <p class="text-muted">Отзывов пока нет.</p>
                }
            </div>
        </div>
    </div>

    <!-- УСЛУГИ -->
    <h4 class="mb-3">Услуги</h4>
    @if (Model.Services == null || !Model.Services.Any())
    {
        <p class="text-muted">У этого фрилансера пока нет услуг.</p>
    }
    else
    {
        foreach (var service in Model.Services)
        {
            double svcAvg = service.Reviews?.Any() == true
                ? service.Reviews.Average(r => r.Rating) : 0.0;
            int svcCount  = service.Reviews?.Count ?? 0;

            <div class="project-card">
                <div class="project-header">
                    <h3 class="project-title">@service.Title</h3>
                    <span class="status-badge @(service.Status == "Available" ? "status-open" : "status-cancelled")">
                        @(service.Status == "Available" ? "Открыта" : "Закрыта")
                    </span>
                </div>

                <div class="project-meta">
                    <!-- Цена -->
                    <div class="meta-item">
                        <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
                        </svg>
                        <span class="project-budget">@service.Price.ToString("C", new CultureInfo("ru-RU"))</span>
                    </div>

                    <!-- Дробный рейтинг услуги -->
                    <div class="meta-item">
                        @await Html.PartialAsync("_StarRating", svcAvg)
                        <span class="ms-1 text-muted" style="font-size:13px;">
                            @svcAvg.ToString("F1") (@svcCount)
                        </span>
                    </div>
                </div>

                <div class="project-actions">
                    <a asp-action="Details" asp-controller="Service"
                       asp-route-id="@service.Id" class="btn btn-outline">
                        Подробнее
                    </a>
                    @if (isOwnProfile && service.Status != "Unavailable")
                    {
                        <a asp-action="Edit" asp-controller="Service"
                           asp-route-id="@service.Id" class="btn btn-warning">
                            Редактировать
                        </a>
                        <form asp-action="Delete" asp-controller="Service"
                              asp-route-id="@service.Id" method="post"
                              class="d-inline" onsubmit="return confirm('Удалить услугу?')">
                            <button type="submit" class="btn btn-danger">Удалить</button>
                        </form>
                    }
                </div>
            </div>
        }
    }
</div>

@functions {
    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Available" => "status-open",
            "Unavailable" => "status-cancelled",
            _ => "status-open"
        };
    }

    private string GetStatusText(string status)
    {
        return status switch
        {
            "Available" => "Открыта",
            "Unavailable" => "Закрыта",
            _ => "Неизвестно"
        };
    }
}