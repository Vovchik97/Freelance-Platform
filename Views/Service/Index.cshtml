@using System.Globalization
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<FreelancePlatform.Models.Service>
@{
    ViewData["Title"] = "Каталог услуг";
    var allCategories = ViewBag.AllCategories as List<FreelancePlatform.Models.Category> ?? new List<FreelancePlatform.Models.Category>();
    var selectedCategories = ViewBag.SelectedCategories as List<int> ?? new List<int>();
}

<div class="container">
    <!-- Header -->
    <div class="header">
        <h1>Каталог услуг</h1>
        <p>Найдите интересные услуги и закажите их уже сегодня</p>
    </div>

    <!-- Filters -->
    <div class="filters-card">
        <div class="filters-title">
            <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.707A1 1 0 013 7V4z"></path>
            </svg>
            Фильтры поиска
        </div>

        <form method="get" id="filterForm">
            <!-- Блок поиска -->
            <div class="filters-search mb-3">
                <label for="search" class="form-label">Поиск по названию</label>
                <div class="search-input">
                    <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                    <input type="text" id="search" name="search" value="@ViewBag.Search" class="form-input" placeholder="Введите название услуги..." />
                </div>
            </div>

            <!-- Категории -->
            @if (allCategories.Any())
            {
                <div class="mb-3">
                    <label class="form-label">Категории</label>
                    <div class="category-actions" style="margin-bottom: 8px; display: flex; gap: 8px;">
                        <button type="button" class="btn btn-outline btn-sm" onclick="selectAllCategories()">Выбрать все</button>
                        <button type="button" class="btn btn-outline btn-sm" onclick="clearAllCategories()">Очистить все</button>
                    </div>
                    <div class="category-chips" style="display: flex; flex-wrap: wrap; gap: 8px;">
                        @foreach (var cat in allCategories)
                        {
                            var isChecked = selectedCategories.Contains(cat.Id);
                            <label class="category-chip @(isChecked ? "category-chip-active" : "")" style="cursor: pointer; display: inline-flex; align-items: center; padding: 6px 14px; border-radius: 20px; border: 2px solid #6c63ff; background: @(isChecked ? "#6c63ff" : "transparent"); color: @(isChecked ? "#fff" : "#6c63ff"); font-size: 14px; font-weight: 500; transition: all 0.2s; user-select: none;">
                                <input type="checkbox" name="categories" value="@cat.Id"
                                       @(isChecked ? "checked" : "")
                                       style="display: none;"
                                       onchange="toggleChip(this)" />
                                @cat.Name
                            </label>
                        }
                    </div>
                </div>
            }

            <!-- Остальные фильтры и кнопка -->
            <div class="filters-row">
                <div class="input-group">
                    <label for="status">Статус</label>
                    <select name="status" id="status" class="form-select" style="width: 100%">
                        <option value="">Все статусы</option>
                        <option value="Available" selected="@(ViewBag.Status == "Available")">Открыта</option>
                        <option value="Unavailable" selected="@(ViewBag.Status == "Unavailable")">Закрыта</option>
                    </select>
                </div>

                <div class="input-group">
                    <label for="minPrice">Мин. цена</label>
                    <input type="number" min="0" step="1" id="minPrice" name="minPrice" value="@ViewBag.MinPrice" class="form-input" placeholder="0" />
                </div>

                <div class="input-group">
                    <label for="maxPrice">Макс. цена</label>
                    <input type="number" min="0" step="1" id="maxPrice" name="maxPrice" value="@ViewBag.MaxPrice" class="form-input" placeholder="∞" />
                </div>

                <div class="input-group">
                    <label for="sort">Сортировка</label>
                    <select name="sort" id="sort" class="form-select" style="width: 100%">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.Sort))">Дата (новые)</option>
                        <option value="price_asc" selected="@(ViewBag.Sort == "price_asc")">Цена ↑</option>
                        <option value="price_desc" selected="@(ViewBag.Sort == "price_desc")">Цена ↓</option>
                    </select>
                </div>

                <div class="submit-group" style="height: 45px">
                    <button type="submit" class="btn-primary w-100">
                        <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                        Найти
                    </button>
                </div>
            </div>
        </form>
    </div>
    
    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Client") && ViewBag.Recommendations != null)
    {
        var recs = ViewBag.Recommendations as List<FreelancePlatform.Dto.Recommendations.RecommendationDto>;
        if (recs != null && recs.Any())
        {
            <div class="filters-card mb-4">
                <h2 class="filters-title">🎯 Рекомендованные услуги</h2>
                <div class="row">
                    @foreach (var item in recs)
                    {
                        <div class="col-md-4 mb-3">
                            <div class="project-card">
                                <h5>@item.Title</h5>
                                <div class="project-meta">
                                    <span class="project-budget">
                                        💰 @item.Budget.ToString("C", new CultureInfo("ru-RU"))
                                    </span>
                                </div>
                                <small class="text-muted">@string.Join(", ", item.Reasons)</small>
                                <div class="mt-2">
                                    <a asp-controller="Service" asp-action="Details"
                                       asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                                        Открыть
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }

    <!-- Services List -->
    <div class="projects-list">
        @if (Model != null && Model.Any())
        {
            @foreach (var service in Model)
            {
                <div class="project-card">
                    <div class="project-header">
                        <h3 class="project-title">@service.Title</h3>
                        <span class="status-badge @GetStatusClass(service.Status.ToString())">
                            @GetStatusText(service.Status.ToString())
                        </span>
                    </div>

                    <!-- Категории услуги -->
                    @if (service.Categories != null && service.Categories.Any())
                    {
                        <div style="display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px;">
                            @foreach (var cat in service.Categories)
                            {
                                <span style="display: inline-block; padding: 2px 10px; border-radius: 12px; background: #e8e6ff; color: #6c63ff; font-size: 12px; font-weight: 500;">
                                    @cat.Name
                                </span>
                            }
                        </div>
                    }

                    <div class="project-meta">
                        <div class="meta-item">
                            <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                            </svg>
                            <span class="project-budget">@service.Price.ToString("C", new CultureInfo("ru-RU"))</span>
                        </div>
                        <div class="meta-item">
                            <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                            <a asp-controller="PublicProfile" asp-action="Public" asp-route-userId="@service.FreelancerId">@service.Freelancer?.Email</a>
                        </div>
                        <div class="meta-item">
                            <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                            <span>@service.CreatedAt.ToString("dd.MM.yyyy")</span>
                        </div>
                        <!-- Средний рейтинг и количество отзывов -->
                        <div class="star-rating mb-2" title="@($"{(service.Reviews?.Any() == true ? service.Reviews.Average(r => r.Rating) : 0):F1} из 5")">
                            <div class="back-stars">
                                ★★★★★
                                <div class="front-stars" style="width:@(service.Reviews?.Any() == true ? service.Reviews.Average(r => r.Rating) / 5.0 * 100 : 0)%">
                                    ★★★★★
                                </div>
                            </div>
                            <span class="ms-2 text-muted">(@(service.Reviews?.Count ?? 0) отзывов)</span>
                        </div>
                    </div>

                    <div class="project-actions">
                        <a asp-action="Details" asp-route-id="@service.Id" class="btn btn-outline">
                            <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                            </svg>
                            Подробнее
                        </a>

                        @if (User.Identity?.IsAuthenticated == true && User.Identity.Name == service.Freelancer?.UserName && service.Status != ServiceStatus.Unavailable)
                        {
                            <a asp-action="Edit" asp-route-id="@service.Id" class="btn btn-warning">
                                <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                </svg>
                                Редактировать
                            </a>
                            <form asp-action="Delete" asp-route-id="@service.Id" method="post" style="display: inline;" onsubmit="return confirm('Удалить услугу?');">
                                <button type="submit" class="btn btn-danger">
                                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                    </svg>
                                    Удалить
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="no-results">
                <svg class="no-results-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <h3>Услуги не найдены</h3>
                <p>Попробуйте изменить параметры поиска</p>
            </div>
        }
    </div>
</div>

<script>
    function toggleChip(checkbox) {
        var label = checkbox.parentElement;
        if (checkbox.checked) {
            label.style.background = '#6c63ff';
            label.style.color = '#fff';
        } else {
            label.style.background = 'transparent';
            label.style.color = '#6c63ff';
        }
    }

    function selectAllCategories() {
        document.querySelectorAll('input[name="categories"]').forEach(function(cb) {
            cb.checked = true;
            toggleChip(cb);
        });
    }

    function clearAllCategories() {
        document.querySelectorAll('input[name="categories"]').forEach(function(cb) {
            cb.checked = false;
            toggleChip(cb);
        });
    }
</script>

@functions {
    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Available" => "status-open",
            "Unavailable" => "status-cancelled",
            _ => "status-open"
        };
    }

    private string GetStatusText(string status)
    {
        return status switch
        {
            "Available" => "Открыта",
            "Unavailable" => "Закрыта",
            _ => "Неизвестно"
        };
    }
}