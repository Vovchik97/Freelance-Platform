@using System.Globalization
@model List<FreelancePlatform.Models.Bid>
@{
    ViewData["Title"] = "Мои отклики";

    var teamProjects = ViewBag.TeamProjects as List<FreelancePlatform.Models.Project> 
                       ?? new List<FreelancePlatform.Models.Project>();
    var invites      = ViewBag.Invites as List<FreelancePlatform.Models.ProjectMember> 
                       ?? new List<FreelancePlatform.Models.ProjectMember>();
    var pendingInvites = invites.Count(i => i.Status == ProjectMemberStatus.Pending);
    var unreadByProject = ViewBag.UnreadByProject as Dictionary<int, int>
                          ?? new Dictionary<int, int>();
    var totalUnreadTeam = unreadByProject.Values.Sum();

    var activeTab = Context.Request.Query["tab"].ToString();
    if (string.IsNullOrEmpty(activeTab)) activeTab = "bids";
}

<div class="container mt-5">
    <div class="header mb-4">
        <h1>Мои отклики</h1>
        <p class="text-secondary">Управляйте своими откликами и командными проектами</p>
    </div>

    <!-- ===== ВКЛАДКИ ===== -->
    <div style="display:flex; gap:4px;
                border-bottom:2px solid var(--border);
                margin-bottom:1.5rem;">

        <!-- Отклики -->
        <a href="?tab=bids"
           style="padding:0.6rem 1.4rem;
                  border-radius:0.5rem 0.5rem 0 0;
                  font-weight:@(activeTab == "bids" ? "600" : "500");
                  font-size:0.9rem;
                  text-decoration:none;
                  color:@(activeTab == "bids" ? "var(--primary-light)" : "var(--text-secondary)");
                  background:@(activeTab == "bids" ? "var(--surface)" : "transparent");
                  border:1px solid @(activeTab == "bids" ? "var(--border)" : "transparent");
                  border-bottom:@(activeTab == "bids" ? "3px solid var(--primary)" : "none");
                  transition:all 0.2s;">
            📋 Отклики
            <span style="background:var(--surface-light);
                         color:var(--text-secondary);
                         border:1px solid var(--border);
                         border-radius:9999px;
                         padding:1px 8px;
                         font-size:0.75rem;
                         margin-left:4px;">
                @Model.Count
            </span>
        </a>

        <!-- Командные проекты -->
        <a href="?tab=team"
           style="padding:0.6rem 1.4rem;
                  border-radius:0.5rem 0.5rem 0 0;
                  font-weight:@(activeTab == "team" ? "600" : "500");
                  font-size:0.9rem;
                  text-decoration:none;
                  color:@(activeTab == "team" ? "var(--primary-light)" : "var(--text-secondary)");
                  background:@(activeTab == "team" ? "var(--surface)" : "transparent");
                  border:1px solid @(activeTab == "team" ? "var(--border)" : "transparent");
                  border-bottom:@(activeTab == "team" ? "3px solid var(--primary)" : "none");
                  transition:all 0.2s;">
            👥 Командные проекты
            <span style="background:var(--surface-light);
                         color:var(--text-secondary);
                         border:1px solid var(--border);
                         border-radius:9999px;
                         padding:1px 8px;
                         font-size:0.75rem;
                         margin-left:4px;">
                @teamProjects.Count
            </span>
            @if (totalUnreadTeam > 0)
            {
                <span id="teamTabBadge"
                      style="background:#ef4444;
                     color:white;
                     border-radius:9999px;
                     padding:1px 8px;
                     font-size:0.75rem;
                     margin-left:2px;
                     font-weight:600;">
                    @totalUnreadTeam
                </span>
            }
            else
            {
                <span id="teamTabBadge" style="display:none;">0</span>
            }
        </a>

        <!-- Приглашения -->
        <a href="?tab=invites"
           style="padding:0.6rem 1.4rem;
                  border-radius:0.5rem 0.5rem 0 0;
                  font-weight:@(activeTab == "invites" ? "600" : "500");
                  font-size:0.9rem;
                  text-decoration:none;
                  color:@(activeTab == "invites" ? "var(--primary-light)" : "var(--text-secondary)");
                  background:@(activeTab == "invites" ? "var(--surface)" : "transparent");
                  border:1px solid @(activeTab == "invites" ? "var(--border)" : "transparent");
                  border-bottom:@(activeTab == "invites" ? "3px solid var(--primary)" : "none");
                  transition:all 0.2s;
                  position:relative;">
            📨 Приглашения
            <span style="background:var(--surface-light);
                 color:var(--text-secondary);
                 border:1px solid var(--border);
                 border-radius:9999px;
                 padding:1px 8px;
                 font-size:0.75rem;
                 margin-left:4px;">
                @invites.Count
            </span>
            @if (pendingInvites > 0)
            {
                // Есть новые — красный с количеством новых
                <span style="background:#ef4444;
                     color:white;
                     border-radius:9999px;
                     padding:1px 8px;
                     font-size:0.75rem;
                     margin-left:4px;
                     font-weight:600;">
                    @pendingInvites
                </span>
            }
        </a>
    </div>

    <!-- ===== ВКЛАДКА: ОТКЛИКИ ===== -->
    @if (activeTab == "bids")
    {
        @if (Model.Any())
        {
            <div class="custom-table-container">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Проект</th>
                            <th>Сумма</th>
                            <th>Срок (дн.)</th>
                            <th>Комментарий</th>
                            <th>Дата</th>
                            <th>Статус</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bid in Model)
                        {
                            <tr>
                                <td>@bid.Project?.Title</td>
                                <td>@bid.Amount ₽</td>
                                <td>@bid.DurationInDays</td>
                                <td>@bid.Comment</td>
                                <td>@bid.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>
                                    @{
                                        var (cls, label) = bid.Status switch
                                        {
                                            BidStatus.Pending  => ("status-pending",  "Рассматривается"),
                                            BidStatus.Accepted => ("status-open",     "Одобрена"),
                                            BidStatus.Rejected => ("status-cancelled","Отклонена"),
                                            _                  => ("status-pending",  "Неизвестно")
                                        };
                                    }
                                    <span class="status-badge @cls">@label</span>
                                </td>
                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        <a class="btn btn-sm btn-outline"
                                           asp-action="Details" asp-route-id="@bid.Id">
                                            Детали
                                        </a>
                                        <a asp-controller="Project" asp-action="Details"
                                           asp-route-id="@bid.Project?.Id"
                                           class="btn btn-sm btn-outline">
                                            Проект
                                        </a>
                                        @if (bid.Status == BidStatus.Pending)
                                        {
                                            <a class="btn btn-sm btn-warning"
                                               asp-action="Edit" asp-route-id="@bid.Id">
                                                Редактировать
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@bid.Id"
                                                  method="post"
                                                  onsubmit="return confirm('Удалить отклик?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    Удалить
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="no-results">
                <p style="font-size:3rem; margin-bottom:0.5rem;">📋</p>
                <h3>Откликов пока нет</h3>
                <p>
                    <a asp-controller="Project" asp-action="Index">
                        Посмотрите проекты
                    </a> и откликнитесь
                </p>
            </div>
        }
    }

    <!-- ===== ВКЛАДКА: КОМАНДНЫЕ ПРОЕКТЫ ===== -->
    @if (activeTab == "team")
    {
        @if (teamProjects.Any())
        {
            <div class="projects-list">
                @foreach (var project in teamProjects)
                {
                    <div class="project-card">
                        <div class="project-header">
                            <h3 class="project-title">@project.Title</h3>
                            <span class="status-badge status-completed">👥 Командный</span>
                            @switch (project.Status)
                            {
                                case ProjectStatus.Open:
                                    <span class="status-badge status-open">Открыт</span>
                                    break;
                                case ProjectStatus.InProgress:
                                    <span class="status-badge status-inprogress">В работе</span>
                                    break;
                                case ProjectStatus.Completed:
                                    <span class="status-badge status-completed">Завершён</span>
                                    break;
                                case ProjectStatus.Cancelled:
                                    <span class="status-badge status-cancelled">Отменён</span>
                                    break;
                                case ProjectStatus.Paid:
                                    <span class="status-badge status-paid">Оплачен</span>
                                    break;
                            }
                        </div>

                        @if (project.Categories != null && project.Categories.Any())
                        {
                            <div style="display:flex; flex-wrap:wrap; gap:4px; margin-bottom:8px;">
                                @foreach (var cat in project.Categories)
                                {
                                    <span style="padding:2px 10px; border-radius:12px;
                                                 background:#e8e6ff; color:#6c63ff;
                                                 font-size:12px; font-weight:500;">
                                        @cat.Name
                                    </span>
                                }
                            </div>
                        }

                        <div class="project-meta">
                            <div class="meta-item">
                                <span class="project-budget">
                                    @project.Budget.ToString("C", new CultureInfo("ru-RU"))
                                </span>
                            </div>
                            <div class="meta-item">
                                <svg class="meta-icon" fill="none"
                                     stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          stroke-width="2"
                                          d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                <span>@project.Client?.UserName</span>
                            </div>
                            <div class="meta-item">
                                <svg class="meta-icon" fill="none"
                                     stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          stroke-width="2"
                                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                                <span>
                                    @project.Members.Count(m => m.Status == ProjectMemberStatus.Accepted)
                                    участников
                                </span>
                            </div>
                            <div class="meta-item">
                                <span>@project.CreatedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>

                        <div class="project-actions">
                            <div style="position:relative; display:inline-block;">
                                <a asp-controller="TeamProject" asp-action="Details"
                                   asp-route-id="@project.Id"
                                   class="btn btn-primary">
                                    Открыть проект
                                </a>
                                @{
                                    var unread = unreadByProject.GetValueOrDefault(project.Id, 0);
                                }
                                @if (unread > 0)
                                {
                                    <span id="unread-@project.Id"
                                          style="position:absolute;
                                          top:-6px; right:-6px;
                                          background:#ef4444;
                                          color:white;
                                          border-radius:9999px;
                                          padding:1px 7px;
                                          font-size:0.7rem;
                                          font-weight:600;
                                          pointer-events:none;">
                                        @unread 💬
                                    </span>
                                }
                                else
                                {
                                    <span id="unread-@project.Id" style="display:none;
                                    position:absolute; top:-6px; right:-6px;
                                    background:#ef4444; color:white;
                                    border-radius:9999px; padding:1px 7px;
                                    font-size:0.7rem; font-weight:600;">
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-results">
                <p style="font-size:3rem; margin-bottom:0.5rem;">👥</p>
                <h3>Нет командных проектов</h3>
                <p>Вы пока не участвуете ни в одном командном проекте</p>
            </div>
        }
    }

    <!-- ===== ВКЛАДКА: ПРИГЛАШЕНИЯ ===== -->
    @if (activeTab == "invites")
    {
        @if (invites.Any())
        {
            <div class="projects-list">
                @foreach (var invite in invites)
                {
                    <div class="project-card">
                        <div class="project-header">
                            <h3 class="project-title">@invite.Project.Title</h3>

                            @* Статус приглашения *@
                            @switch (invite.Status)
                            {
                                case ProjectMemberStatus.Pending:
                                    <span class="status-badge status-pending">
                                        ⏳ Ожидает ответа
                                    </span>
                                    break;
                                case ProjectMemberStatus.Accepted:
                                    <span class="status-badge status-open">
                                        ✅ Принято
                                    </span>
                                    break;
                                case ProjectMemberStatus.Rejected:
                                    <span class="status-badge status-cancelled">
                                        ✕ Отклонено
                                    </span>
                                    break;
                            }
                        </div>

                        <div class="project-meta">
                            <div class="meta-item">
                                <span>
                                    Роль: @(invite.Role == ProjectMemberRole.Lead
                                        ? "⭐ Lead"
                                        : "Участник")
                                </span>
                            </div>
                            <div class="meta-item">
                                <span>
                                    Бюджет: @invite.Project.Budget.ToString("C", new CultureInfo("ru-RU"))
                                </span>
                            </div>
                            <div class="meta-item">
                                <span>
                                    @invite.JoinedAt.ToString("dd.MM.yyyy")
                                </span>
                            </div>
                        </div>

                        <div class="project-actions">
                            <a asp-controller="TeamProject" asp-action="Details"
                               asp-route-id="@invite.ProjectId"
                               class="btn btn-outline">
                                Посмотреть проект
                            </a>

                            @* Кнопки только для pending *@
                            @if (invite.Status == ProjectMemberStatus.Pending)
                            {
                                <form asp-controller="TeamProject" asp-action="AcceptInvite"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="memberId" value="@invite.Id"/>
                                    <button class="btn btn-primary">✅ Принять</button>
                                </form>
                                <form asp-controller="TeamProject" asp-action="DeclineInvite"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="memberId" value="@invite.Id"/>
                                    <button class="btn btn-danger">✕ Отклонить</button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-results">
                <p style="font-size:3rem; margin-bottom:0.5rem;">📨</p>
                <h3>Приглашений нет</h3>
                <p>Здесь появятся приглашения в командные проекты</p>
            </div>
        }
    }
</div>