@page
@model FreelancePlatform.Areas.Identity.Pages.Admin.Categories.IndexModel
@{
    ViewData["Title"] = "Управление категориями";
}

<div class="container">
    <div class="header">
        <h1>Управление категориями</h1>
        <p>Создавайте и управляйте категориями для проектов и услуг</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="mb-3">
        <a asp-page="Create" class="btn btn-primary">
            + Добавить категорию
        </a>
    </div>

    <div class="filters-card">
        <table class="custom-table table-bordered table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Описание</th>
                    <th>Статус</th>
                    <th>Проектов</th>
                    <th>Услуг</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model.Categories.OrderByDescending(c => c.CreatedAt))
                {
                    <tr style="@(category.IsActive ? "" : "opacity: 0.6;")">
                        <td>@category.Id</td>
                        <td><strong>@category.Name</strong></td>
                        <td>@(category.Description ?? "—")</td>
                        <td>
                            <span class="status-badge @(category.IsActive ? "status-open" : "status-cancelled")">
                                @(category.IsActive ? "Активна" : "Неактивна")
                            </span>
                        </td>
                        <td>@(Model.ProjectCounts.GetValueOrDefault(category.Id, 0))</td>
                        <td>@(Model.ServiceCounts.GetValueOrDefault(category.Id, 0))</td>
                        <td>
                            <div style="display: flex; gap: 5px; flex-wrap: wrap;">
                                <a asp-page="Edit" asp-route-id="@category.Id" class="btn btn-warning btn-sm">
                                    Изменить
                                </a>
                                <form method="post" asp-page-handler="ToggleActive" style="display:inline;">
                                    <input type="hidden" name="id" value="@category.Id" />
                                    <button type="submit" class="btn @(category.IsActive ? "btn-outline" : "btn-primary") btn-sm">
                                        @(category.IsActive ? "Деактивировать" : "Активировать")
                                    </button>
                                </form>
                                <form method="post" asp-page-handler="Delete" style="display:inline;"
                                      onsubmit="return confirm('Удалить категорию?');">
                                    <input type="hidden" name="id" value="@category.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>