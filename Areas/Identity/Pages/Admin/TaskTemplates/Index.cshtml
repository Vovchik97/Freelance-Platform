@page
@using FreelancePlatform.Models
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model FreelancePlatform.Areas.Identity.Pages.Admin.TaskTemplates.IndexModel
@{
    ViewData["Title"] = "Шаблоны задач";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📋 Шаблоны задач</h2>
    <a asp-page="Create" class="btn btn-primary">➕ Новый шаблон</a>
</div>

@if (Model.Templates.Any())
{
    <div class="table-responsive">
        <table class="custom-table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Описание</th>
                    <th>Категории</th>
                    <th>Задач</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var template in Model.Templates)
                {
                    <tr>
                        <td>
                            <strong>@template.Name</strong>
                        </td>
                        <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis;">
                            @if (!string.IsNullOrWhiteSpace(template.Description))
                            {
                                @template.Description
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (template.Categories.Any())
                            {
                                <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                                    @foreach (var category in template.Categories.Take(3))
                                    {
                                        <span class="badge bg-info">@category.Name</span>
                                    }
                                    @if (template.Categories.Count > 3)
                                    {
                                        <span class="badge bg-secondary">+@(template.Categories.Count - 3)</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">Нет</span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-primary">@template.Items.Count</span>
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <a asp-page="Edit" asp-route-id="@template.Id"
                                   class="btn btn-sm btn-outline-warning">
                                    ✏️ Редактировать
                                </a>
                                <a asp-page="Details" asp-route-id="@template.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    👁️ Просмотр
                                </a>
                                <form method="post" asp-page-handler="Delete"
                                      asp-route-id="@template.Id" class="d-inline">
                                    <button class="btn btn-sm btn-danger"
                                            onclick="return confirm('Вы уверены?')">
                                        🗑️ Удалить
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info" role="alert">
        <strong>📭 Шаблонов нет</strong><br>
        Начните с создания первого шаблона задач.
        <a asp-page="Create" class="btn btn-sm btn-primary mt-2">Создать шаблон</a>
    </div>
}