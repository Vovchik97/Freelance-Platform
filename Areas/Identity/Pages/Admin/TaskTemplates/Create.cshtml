@page
@using FreelancePlatform.Models
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model FreelancePlatform.Areas.Identity.Pages.Admin.TaskTemplates.CreateModel
@{
    ViewData["Title"] = "Создать шаблон";
}

<h2>➕ Создать шаблон</h2>

<form method="post" class="mt-4">
    <div class="row">
        <div class="col-lg-8">
            <!-- Название -->
            <div class="mb-3">
                <label asp-for="Input.Name" class="form-label">Название</label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>

            <!-- Описание -->
            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label">Описание</label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>

            <!-- Категории -->
            <div class="mb-3">
                <label class="form-label">Категории</label>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px;">
                    @foreach (var category in Model.AllCategories)
                    {
                        <div class="form-check" style="padding: 8px 12px; border: 2px solid var(--border); border-radius: 6px;">
                            <input class="form-check-input" type="checkbox"
                                   name="categoryIds" value="@category.Id"
                                   id="cat_@category.Id" />
                            <label class="form-check-label" for="cat_@category.Id">
                                @category.Name
                            </label>
                        </div>
                    }
                </div>
            </div>

            <!-- Задачи -->
            <div class="mb-3">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                    <label class="form-label" style="margin-bottom: 0;">Задачи шаблона</label>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="addTaskRow()">
                        ➕ Добавить задачу
                    </button>
                </div>

                <div id="tasksContainer">
                    <!-- Задачи будут добавляться сюда -->
                </div>
                <div class="mt-2">
                    <small>⚠️ Добавьте хотя бы одну задачу</small>
                </div>
            </div>

            <!-- Кнопки -->
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">💾 Создать</button>
                <a asp-page="Index" class="btn btn-secondary">← Отмена</a>
            </div>
        </div>
    </div>
</form>

<style>
    .form-control {
        background-color: var(--surface) !important;
        border-color: var(--border) !important;
        color: var(--text-primary) !important;
    }
    .form-control::placeholder {
        color: var(--text-secondary);
        opacity: 0.7;
    }
    .form-control:focus {
        background-color: var(--surface) !important;
        border-color: var(--primary) !important;
        color: var(--text-primary) !important;
        box-shadow: 0 0 0 0.2rem rgba(108, 99, 255, 0.25);
    }
    textarea.form-control {
        resize: vertical;
    }
    .form-check {
        transition: all 0.2s ease;
        cursor: pointer;
    }
    .form-check:hover {
        background-color: var(--surface-light) !important;
    }
</style>

@section Scripts {
    <script>
        let taskCounter = 0;
        
        // Добавляем одну пустую задачу по умолчанию при загрузке страницы
        document.addEventListener('DOMContentLoaded', function() {
            addTaskRow();
        });
        
        function addTaskRow() {
            const container = document.getElementById('tasksContainer');
            const index = taskCounter++;
            
            const html = `
                <div class="card mb-2" data-task-index="${index}" style="background-color: var(--surface-light); border-color: var(--border);">
                    <div class="card-body p-3">
                        <div class="row g-2 mb-2">
                            <div class="col-md-10">
                                <input type="text" name="Input.Items[${index}].Title" class="form-control" placeholder="Название задачи" required />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-sm btn-danger w-100" onclick="removeTaskRow(this, ${index})">
                                    ✕ Удалить
                                </button>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <textarea name="Input.Items[${index}].Description" class="form-control" rows="2" placeholder="Описание задачи (необязательно)"></textarea>
                            </div>
                        </div>
                        <input type="hidden" name="Input.Items[${index}].OrderIndex" value="${index + 1}" />
                    </div>
                </div>
            `;
            
            container.insertAdjacentHTML('beforeend', html);
            reindexTasks();
        }
        
        function removeTaskRow(button, index) {
            const taskDiv = button.closest('.card');
            taskDiv.remove();
            reindexTasks();
        }
        
        function reindexTasks() {
            const tasks = document.querySelectorAll('#tasksContainer .card');
            tasks.forEach((task, newIndex) => {
                // Обновляем data-атрибут
                task.setAttribute('data-task-index', newIndex);
                
                // Обновляем name атрибуты всех полей внутри задачи
                const titleInput = task.querySelector('input[name*=".Title"]');
                const descTextarea = task.querySelector('textarea[name*=".Description"]');
                const orderInput = task.querySelector('input[name*=".OrderIndex"]');
                
                if (titleInput) {
                    titleInput.name = `Input.Items[${newIndex}].Title`;
                }
                if (descTextarea) {
                    descTextarea.name = `Input.Items[${newIndex}].Description`;
                }
                if (orderInput) {
                    orderInput.name = `Input.Items[${newIndex}].OrderIndex`;
                    orderInput.value = newIndex + 1;
                }
                
                // Обновляем onclick у кнопки удаления
                const deleteBtn = task.querySelector('.btn-danger');
                if (deleteBtn) {
                    deleteBtn.setAttribute('onclick', `removeTaskRow(this, ${newIndex})`);
                }
            });
            
            taskCounter = tasks.length;
        }
        
        // Валидация перед отправкой формы
        document.querySelector('form').addEventListener('submit', function(e) {
            const tasks = document.querySelectorAll('#tasksContainer .card');
            if (tasks.length === 0) {
                e.preventDefault();
                alert('Добавьте хотя бы одну задачу в шаблон');
                return false;
            }
            
            // Проверяем, что у всех задач заполнено название
            let hasEmptyTitle = false;
            tasks.forEach(task => {
                const titleInput = task.querySelector('input[name*=".Title"]');
                if (titleInput && !titleInput.value.trim()) {
                    hasEmptyTitle = true;
                    titleInput.style.borderColor = '#dc3545';
                } else if (titleInput) {
                    titleInput.style.borderColor = 'var(--border)';
                }
            });
            
            if (hasEmptyTitle) {
                e.preventDefault();
                alert('Пожалуйста, заполните названия всех задач');
                return false;
            }
        });
    </script>
}