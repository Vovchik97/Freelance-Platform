@page
@using FreelancePlatform.Models
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model FreelancePlatform.Areas.Identity.Pages.Admin.Projects.IndexModel
@{
    ViewData["Title"] = "Проекты";
}

<h2>Проекты</h2>

<table class="custom-table table-bordered table-striped">
    <thead>
        <tr>
            <th>Тип</th>
            <th>Название</th>
            <th>Клиент</th>
            <th>Бюджет</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var project in Model.Projects)
        {
            <tr>
                <td>
                    @if (project.IsTeamProject)
                    {
                        <span class="badge"
                              style="background:var(--primary); color:white;">
                            👥 Командный
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-primary">
                            Обычный
                        </span>
                    }
                </td>
                <td>@project.Title</td>
                <td>@project.Client?.UserName</td>
                <td>@project.Budget.ToString("C", new System.Globalization.CultureInfo("ru-RU"))</td>
                <td>@GetStatusText(project.Status.ToString())</td>
                <td>
                    <div class="d-flex flex-wrap gap-1">
                        @if (project.Status == ProjectStatus.Open)
                        {
                            <form method="post" asp-page-handler="Close"
                                  asp-route-id="@project.Id" class="d-inline">
                                <button class="btn btn-sm btn-warning">Закрыть</button>
                            </form>
                        }
                        else if (project.Status == ProjectStatus.Cancelled)
                        {
                            <form method="post" asp-page-handler="Open"
                                  asp-route-id="@project.Id" class="d-inline">
                                <button class="btn btn-sm btn-success">Открыть</button>
                            </form>
                        }
                        <form method="post" asp-page-handler="Delete"
                              asp-route-id="@project.Id" class="d-inline">
                            <button class="btn btn-sm btn-danger">Удалить</button>
                        </form>
                        <a asp-page="Details" asp-route-id="@project.Id"
                           class="btn btn-sm btn-outline-primary">
                            Подробнее
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@functions
{
    private string GetStatusText(string status)
    {
        return status switch
        {
            "Open"       => "Открыт",
            "Paid"       => "Оплачен",
            "InProgress" => "В работе",
            "Cancelled"  => "Отменён",
            "Completed"  => "Выполнен",
            _            => "Неизвестно"
        };
    }
}