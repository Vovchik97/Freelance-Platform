@page
@using FreelancePlatform.Models
@model FreelancePlatform.Areas.Identity.Pages.Admin.Payments.IndexModel
@{
    ViewData["Title"] = "Платежи";
}

<h2>Платежи</h2>

<table class="custom-table table-bordered table-striped">
    <thead>
    <tr>
        <th>ID</th>
        <th>Пользователь</th>
        <th>Сумма</th>
        <th>Тип</th>
        <th>Статус</th>
        <th>Дата</th>
        <th>Действия</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Payments)
    {
        <tr>
            <td>@item.Payment.Id</td>
            <td>@item.UserEmail</td>
            <td>@(item.Payment.AmountMinor / 100m) @item.Payment.Currency</td>
            <td>@item.Payment.Type</td>
            <td>@GetActualStatus(item.Payment)</td>
            <td>@item.Payment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
            <td>
                <a asp-page="Details" asp-route-id="@item.Payment.Id" class="btn btn-sm btn-primary">
                    Подробнее
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>

@functions {
    private string GetActualStatus(Payment payment)
    {
        if (payment.Status == PaymentStatus.Pending &&
            (payment.Type == PaymentType.Deposit || payment.Type == PaymentType.Withdrawal))
        {
            return "Canceled";
        }
        return payment.Status.ToString(); 
    }
}